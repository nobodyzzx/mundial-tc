                    {/* Ya pronosticado: mostrar score de penales si aplica */}
                    {existing && (existing.user_home_pen !== null || existing.user_winner_penalties) && (
                      <p class="text-xs text-slate-500 text-center mt-2">
                        Penales: <span class="text-gold">
                          {existing.user_home_pen !== null
                            ? `${existing.user_home_pen} – ${existing.user_away_pen}`
                            : existing.user_winner_penalties === 'home' ? spanishName(m.home_team) : spanishName(m.away_team)
                          }
                        </span>
                      </p>
                    )}
                  </div>
                );
              })}

              <button type="submit"
                class="w-full bg-gold text-brand-950 font-bold py-4 rounded-2xl transition active:bg-gold-dark text-base min-h-[52px] mt-1">
                Enviar pronósticos de la jornada ✅
              </button>
              <p class="text-xs text-slate-600 text-center pb-1">
                Tolerancia Cero — una vez enviado no se puede modificar.
              </p>
            </form>

            {/* Vista de solo-lectura para el CIERRE EN VIVO (oculta): misma marca
                que una jornada cerrada normal. initCountdown oculta el form y la
                muestra al llegar el contador a 0 → queda idéntica al solo-lectura. */}
            <div data-cerrada-view class="hidden space-y-2">
              {jornadaMatches.map((m) => {
                const existing = predMap.get(m.id);
                return (
                  <div class={`bg-brand-900 border rounded-2xl p-4 ${existing ? 'border-gol/30 bg-gol/5' : 'border-fifared/30 bg-fifared/5'}`}>
                    <div class="flex items-center justify-between mb-2">
                      <span class="text-slate-400 font-medium text-xs">
                        {m.stage === 'group' ? (m.group_name ? `Grupo ${m.group_name}` : m.jornada) : m.round}
                      </span>
                      <div class="text-right">
                        <p class="text-xs text-slate-500">{formatShortDate(m.match_date)}</p>
                        <p class="font-display text-base font-bold text-gold leading-tight">{formatTime(m.match_date)}</p>
                      </div>
                    </div>
                    <div class="flex items-center gap-2">
                      <div class="flex-1 min-w-0">
                        <TeamName team={m.home_team} side="home" class={`font-semibold text-base ${existing ? 'text-white' : 'text-slate-400'}`} />
                      </div>
                      <div class="flex-shrink-0 px-2 text-center min-w-[60px]">
                        {existing
                          ? <span class="text-gol font-display text-2xl">{existing.user_home}–{existing.user_away}</span>
                          : <span class="text-slate-700 font-bold text-xl">–</span>
                        }
                      </div>
                      <div class="flex-1 min-w-0">
                        <TeamName team={m.away_team} side="away" class={`font-semibold text-base ${existing ? 'text-white' : 'text-slate-400'}`} />
                      </div>
                    </div>
                    {!existing && (
                      <button disabled class="w-full mt-2 flex items-center justify-center gap-2 text-sm rounded-xl py-3 cursor-not-allowed opacity-75 text-slate-300 bg-brand-800/50 border border-brand-700/50">
                        🔒 Jornada cerrada, sin pronóstico
                      </button>
                    )}
                  </div>
                );
              })}
            </div>
            </Fragment>

          ) : (
            /* ── Jornada cerrada o completa: solo lectura ── */
            <div class="space-y-2">
              {jornadaMatches.map((m) => {
                const existing = predMap.get(m.id);
                return (
                  <div class={`bg-brand-900 border rounded-2xl p-4 ${existing ? 'border-gol/30 bg-gol/5' : prevPending ? 'border-brand-700/40 bg-brand-800/30' : 'border-fifared/30 bg-fifared/5'}`} data-saved-match={existing ? m.id : undefined}>
                    <div class="flex items-center justify-between mb-2">
                      <span class="text-slate-400 font-medium text-xs">
                        {m.stage === 'group' ? (m.group_name ? `Grupo ${m.group_name}` : m.jornada) : m.round}
                      </span>
                      <div class="text-right">
                        <p class="text-xs text-slate-500">{formatShortDate(m.match_date)}</p>
                        <p class="font-display text-base font-bold text-gold leading-tight">{formatTime(m.match_date)}</p>
                      </div>
                    </div>
                    <div class="flex items-center gap-2">
                      <div class="flex-1 min-w-0">
                        <TeamName team={m.home_team} side="home" class={`font-semibold text-base ${existing ? 'text-white' : 'text-slate-400'}`} />
                      </div>
                      <div class="flex-shrink-0 px-2 text-center min-w-[60px]">
                        {existing
                          ? <span class="text-gol font-display text-2xl">{existing.user_home}–{existing.user_away}</span>
                          : <span class="text-slate-700 font-bold text-xl">–</span>
                        }
                      </div>
                      <div class="flex-1 min-w-0">
                        <TeamName team={m.away_team} side="away" class={`font-semibold text-base ${existing ? 'text-white' : 'text-slate-400'}`} />
                      </div>
                    </div>
                    {existing && (existing.user_home_pen !== null || existing.user_winner_penalties) && (
                      <p class="text-xs text-slate-500 text-center mt-1.5">
                        Penales: <span class="text-gold">
                          {existing.user_home_pen !== null
                            ? `${existing.user_home_pen} – ${existing.user_away_pen}`
                            : existing.user_winner_penalties === 'home' ? spanishName(m.home_team) : spanishName(m.away_team)
                          }
                        </span>
                      </p>
                    )}
                    {!existing && (sanctioned || closed) && (
                      <button disabled class={`w-full mt-2 flex items-center justify-center gap-2 text-sm rounded-xl py-3 cursor-not-allowed opacity-75 ${sanctioned ? 'text-fifared bg-fifared/10 border border-fifared/40' : 'text-slate-300 bg-brand-800/50 border border-brand-700/50'}`}>
                        {sanctioned
                          ? (isExpulsado ? '🟥🟥 Expulsado, sin pronóstico' : '🟥 Jornada anulada por tarjeta roja')
                          : '🔒 Jornada cerrada, sin pronóstico'}
                      </button>
                    )}
                  </div>
                );
              })}
            </div>
          )}
          </div>

        </details>
      );
    })}
  </div>

  {/* ── Modal de confirmación antes de enviar ── */}
  <div id="confirm-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4">
    <div class="backdropIn absolute inset-0 bg-brand-950/80 backdrop-blur-md" data-confirm-cancel></div>
    <div class="modalIn relative w-full max-w-sm rounded-[28px] p-6 space-y-4 ring-1 ring-brand-700/70 bg-gradient-to-b from-brand-900 to-brand-950 shadow-2xl">
      <div class="text-center space-y-1.5">
        <div class="iconPop mx-auto w-14 h-14 rounded-full grid place-items-center text-2xl bg-gold/12 ring-1 ring-gold/40">📋</div>
        <h3 class="font-display text-xl text-white tracking-wide">¿CONFIRMAR ENVÍO?</h3>
        <p class="text-xs text-slate-500">Revisa tus marcadores. Una vez enviado no se puede cambiar.</p>
      </div>
      <div id="confirm-list" class="space-y-1.5 max-h-[45vh] overflow-y-auto"></div>
      <div class="flex gap-2 pt-1">
        <button type="button" data-confirm-cancel class="flex-1 bg-brand-800 border border-brand-700 text-slate-300 font-semibold py-3 rounded-2xl hover:bg-brand-700 active:brightness-95 transition min-h-[48px]">Volver</button>
        <button type="button" id="confirm-ok" class="flex-1 bg-gradient-to-b from-gold to-amber-500 text-brand-950 font-bold py-3 rounded-2xl shadow-lg shadow-gold/25 hover:brightness-110 active:brightness-95 transition min-h-[48px]">Confirmar ✅</button>
      </div>
    </div>
  </div>
</Layout>

<script>
  async function copyText(text: string): Promise<boolean> {
    try { await navigator.clipboard.writeText(text); return true; } catch { /* fallback */ }
    // Fallback síncrono (Firefox / permiso denegado): textarea + execCommand durante el click
    try {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.setAttribute('readonly', '');
      ta.style.cssText = 'position:fixed;top:0;left:0;opacity:0';
      document.body.appendChild(ta);
      ta.focus(); ta.select();
      const ok = (document as any).execCommand('copy'); // fallback legacy (Firefox)
      ta.remove();
      return ok;
    } catch { return false; }
  }

  async function waShare(text: string) {
    // 1. Web Share API nativo (móvil y algunos desktop) — detección de característica,
    //    NO sniff de User-Agent (que fallaba en Androids y iPad → caía a "copiar" como PC).
    if (navigator.share) {
      try { await navigator.share({ text }); return; } catch (e) {
        if ((e as Error).name === 'AbortError') return; // usuario canceló
      }
    }
    const waUrl = 'https://wa.me/?text=' + encodeURIComponent(text);
    // 2. Móvil sin Web Share API: abrir wa.me (app de WhatsApp).
    if (/Android|iPhone|iPad|iPod/i.test(navigator.userAgent)) {
      window.open(waUrl, '_blank');
      return;
    }
    // 3. Desktop: copiar (WhatsApp web mangla emojis); si falla, abrir wa.me web.
    const copied = await copyText(text);
    if (!copied) { window.open(waUrl, '_blank'); return; }
    const el = document.createElement('div');
    el.textContent = '\uD83D\uDCCB Copiado \u2014 peg\u00e1lo en WhatsApp con Ctrl+V';
    el.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0d1117;border:1px solid #25d366;color:#fff;padding:12px 20px;border-radius:12px;font-size:14px;z-index:9999;pointer-events:none;white-space:nowrap';
    document.body.appendChild(el);
    setTimeout(() => { el.style.transition = 'opacity .3s'; el.style.opacity = '0'; setTimeout(() => el.remove(), 300); }, 3500);
  }

  // Generar emojis de bandera en runtime
  function flagFromISO(cc: string): string {
    const base = 0x1F1E6 - 65;
    return String.fromCodePoint(cc.charCodeAt(0) + base, cc.charCodeAt(1) + base);
  }

  function initFlags() {
    document.querySelectorAll<HTMLSpanElement>('.flag-emoji').forEach(el => {
      const iso = el.dataset.iso;
      if (iso) el.textContent = flagFromISO(iso);
    });
  }

  // Mostrar selector de penales en partidos de knockout cuando hay empate
  function initPenaltySections() {
    document.querySelectorAll<HTMLInputElement>('input[type="number"]').forEach(input => {
      const name = input.name; // home_N o away_N
      const match = name.match(/^(home|away)_(\d+)$/);
      if (!match) return;
      const idx = match[2];
      const section = document.querySelector<HTMLElement>(`[data-pen-section="pen-section-${idx}"]`);
      if (!section) return;

      function check() {
        const homeVal = (document.querySelector<HTMLInputElement>(`input[name="home_${idx}"]`))?.value;
        const awayVal = (document.querySelector<HTMLInputElement>(`input[name="away_${idx}"]`))?.value;
        const h = parseInt(homeVal ?? '');
        const a = parseInt(awayVal ?? '');
        if (!isNaN(h) && !isNaN(a) && h === a) {
          section!.classList.remove('hidden');
        } else {
          section!.classList.add('hidden');
          section!.querySelectorAll<HTMLInputElement>('input[type="number"]').forEach(r => { r.value = ''; });
        }
      }
      input.addEventListener('input', check);
    });
  }

  // WhatsApp share
  function buildText(data: {
    username: string; cutoff: string;
    items: Array<{ home: string; away: string; homeISO: string; awayISO: string; uh: number; ua: number; uhp: number|null; uap: number|null; pen: string | null }>;
  }) {
    const lines = [
      `\u26BD *Pron\u00f3sticos de ${data.username}*`,
      `_Cierre: ${data.cutoff}_`,
      '',
    ];
    data.items.forEach(item => {
      const hf = item.homeISO ? flagFromISO(item.homeISO) : '';
      const af = item.awayISO ? flagFromISO(item.awayISO) : '';
      lines.push(`${item.home} ${hf} ${item.uh}\u2013${item.ua} ${af} ${item.away}`);
      if (item.pen) {
        const wf    = item.pen === 'home' ? hf : af;
        const wName = item.pen === 'home' ? item.home : item.away;
        const penScore = item.uhp !== null ? `${item.uhp}\u2013${item.uap} pen \u00B7 ` : '';
        lines.push(`_(${penScore}clasifica ${wf} ${wName})_`);
      }
      lines.push('');
    });
    lines.push(`_Polla Mundial 2026_ \uD83C\uDFC6`);
    return lines.join('\n');
  }

  function initShareButtons() {
    document.querySelectorAll<HTMLButtonElement>('.share-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        // El botón vive dentro del <summary>; evita que el click abra/cierre el acordeón.
        e.preventDefault();
        e.stopPropagation();
        const data = JSON.parse(btn.dataset.share ?? '{}');
        waShare(buildText(data));
      });
    });
  }

  // ── Contador en vivo del cierre (verde > 1h, ámbar < 1h, rojo al cerrar) ──
  function fmtRemaining(ms: number): string {
    const t = Math.floor(ms / 1000);
    const h = Math.floor(t / 3600);
    const m = Math.floor((t % 3600) / 60);
    const s = t % 60;
    if (h > 0) return `${h}h ${m}m`;
    if (m > 0) return `${m}m ${s}s`;
    return `${s}s`;
  }

  // Cierre EN VIVO: oculta el formulario editable y muestra la vista de solo-
  // lectura [data-cerrada-view] que el servidor ya renderizó (oculta) con la
  // MISMA marca que una jornada cerrada normal → queda idéntica, sin steppers.
  function lockFormReadonly(form: HTMLFormElement) {
    if (form.dataset.locked) return;
    form.dataset.locked = '1';
    form.style.display = 'none';
    form.parentElement?.querySelector('[data-cerrada-view]')?.classList.remove('hidden');
    // Encabezado igual al de una jornada cerrada (caso 3): fondo rojizo y sin el
    // contador de progreso "X/Y".
    const summary = form.closest('[data-jornada]')?.querySelector('summary');
    if (summary) {
      summary.classList.remove('bg-brand-800/60', 'border-brand-700/60', 'bg-gol/8', 'border-gol/30');
      summary.classList.add('bg-fifared/8', 'border-fifared/30');
      summary.querySelectorAll('[data-progress]').forEach(el => { (el as HTMLElement).style.display = 'none'; });
    }
  }

  function initCountdown() {
    if ((window as any).__cdInterval) clearInterval((window as any).__cdInterval);
    const els = Array.from(document.querySelectorAll<HTMLElement>('.cutoff-cd'));
    const sticky = document.getElementById('sticky-cd');
    const stickyTime = sticky?.querySelector<HTMLElement>('.sticky-cd-time') ?? null;
    const stickyLabelEl = sticky?.querySelector<HTMLElement>('.sticky-cd-label') ?? null;
    const stickyIco = sticky?.querySelector<HTMLElement>('.sticky-cd-ico') ?? null;
    if (!els.length && !sticky) return;

    const URGENT = ['bg-fifared/90', 'border-fifared', 'animate-pulse'];
    const buzz = (pattern: number | number[]) => { try { (navigator as any).vibrate?.(pattern); } catch { /* sin soporte */ } };

    const tick = () => {
      // Encabezados por jornada (texto chico) — comportamiento existente.
      els.forEach(cd => {
        const cutoff = parseInt(cd.dataset.cutoff || '0', 10);
        const rem = cutoff - Date.now();
        if (rem <= 0) {
          cd.textContent = '🔒 Cerrada'; // mismo texto que la jornada cerrada del caso 3
          cd.style.color = '#f87171';
          const wrap = cd.closest('[data-jornada]');
          const form = wrap?.querySelector<HTMLFormElement>('form[action="/api/predictions/submit-jornada"]');
          // Cierre EN VIVO: transformar el formulario al mismo solo-lectura que el
          // servidor (sin steppers, "Jornada cerrada, sin pronóstico"), para que no
          // confunda como si aún se pudiera pronosticar.
          if (form) lockFormReadonly(form);
          return;
        }
        cd.textContent = '⏰ Cierra en ' + fmtRemaining(rem);
        cd.style.color = rem > 3600000 ? '#4ade80' : rem > 600000 ? '#fbbf24' : '#f87171';
      });

      // Barra fija grande (C) con estado "al filo" (D): <5 min se pone roja,
      // pulsa y vibra una vez; <1 min vibra de nuevo más fuerte.
      if (sticky && stickyTime) {
        const cutoff = parseInt(sticky.dataset.cutoff || '0', 10);
        const rem = cutoff - Date.now();
        if (rem <= 0) {
          // Intercambio limpio: oculta la cuenta regresiva y muestra la CerradaBar
          // (misma marca que el caso 3) → formato idéntico, sin fondo gris.
          sticky.classList.add('hidden');
          document.querySelector('[data-cerrada-bar]')?.classList.remove('hidden');
          // Cerró EN VIVO con el formulario aún abierto → bloquear con popup a
          // pantalla completa para que no quede la falsa impresión de que hay tiempo.
          const openForm = document.querySelector('form[action="/api/predictions/submit-jornada"]');
          const cierre = document.getElementById('cierre-modal');
          const k = sticky.dataset.stickyKey || '';
          // En beta/dev nunca se suprime (siempre se muestra, para grabar sin incógnito).
          const yaVisto = import.meta.env.PUBLIC_BETA !== 'true' && k && localStorage.getItem('cierreSeen:' + k);
          if (openForm && cierre && cierre.classList.contains('hidden') && !cierre.dataset.dismissed && !yaVisto) {
            if (k) cierre.dataset.liveKey = k;
            cierre.classList.remove('hidden');
          }
          return;
        }
        stickyTime.textContent = fmtRemaining(rem);
        if (rem <= 300000) {
          // < 5 min → URGENTE (D)
          stickyTime.style.color = '#fff';
          if (stickyIco) stickyIco.textContent = '⚠️';
          if (stickyLabelEl) { stickyLabelEl.style.textTransform = 'none'; stickyLabelEl.textContent = '¡Envía YA antes del cierre!'; }
          sticky.classList.add(...URGENT);
          if (!sticky.dataset.buzz5) { sticky.dataset.buzz5 = '1'; buzz([120, 60, 120]); }
          if (rem <= 60000 && !sticky.dataset.buzz1) { sticky.dataset.buzz1 = '1'; buzz([200, 80, 200, 80, 200]); }
        } else {
          sticky.classList.remove(...URGENT);
          if (stickyIco) stickyIco.textContent = '⏰';
          if (stickyLabelEl) { stickyLabelEl.style.textTransform = ''; stickyLabelEl.textContent = stickyLabelEl.dataset.label ?? ''; }
          stickyTime.style.color = rem > 3600000 ? '#4ade80' : '#fbbf24';
        }
      }
    };
    tick();
    (window as any).__cdInterval = setInterval(tick, 1000);
  }

  // ── Confirmación antes de enviar ──
  function summaryRows(form: HTMLFormElement) {
    const rows: { home: string; away: string; hs: string; as: string; pen: string }[] = [];
    form.querySelectorAll<HTMLInputElement>('input[name^="home_"]').forEach(hi => {
      const idx = hi.name.slice(5);
      const ai = form.querySelector<HTMLInputElement>(`input[name="away_${idx}"]`);
      if (!ai) return;
      const ph = form.querySelector<HTMLInputElement>(`input[name="pen_home_${idx}"]`);
      const pa = form.querySelector<HTMLInputElement>(`input[name="pen_away_${idx}"]`);
      let pen = '';
      if (ph && pa && ph.value !== '' && pa.value !== '') pen = ` · pen ${ph.value}–${pa.value}`;
      rows.push({ home: hi.dataset.team || '', away: ai.dataset.team || '', hs: hi.value, as: ai.value, pen });
    });
    return rows;
  }

  function initConfirmSubmit() {
    const modal = document.getElementById('confirm-modal');
    const list = document.getElementById('confirm-list');
    const okBtn = document.getElementById('confirm-ok');
    if (!modal || !list || !okBtn) return;

    document.querySelectorAll<HTMLFormElement>('form[action="/api/predictions/submit-jornada"]').forEach(form => {
      if (form.dataset.confirmBound) return;
      form.dataset.confirmBound = '1';
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const rows = summaryRows(form);
        list.innerHTML = rows.map(r =>
          `<div class="flex items-center justify-between gap-2 bg-brand-800/50 rounded-lg px-3 py-2">
             <span class="text-sm text-slate-300 truncate">${r.home} <span class="text-slate-600">vs</span> ${r.away}</span>
             <span class="font-display text-lg text-gold flex-shrink-0">${r.hs}–${r.as}<span class="text-[10px] text-slate-400">${r.pen}</span></span>
           </div>`).join('');
        (window as any).__pendingForm = form;
        modal.classList.remove('hidden');
      });
    });

    if (!okBtn.dataset.bound) {
      okBtn.dataset.bound = '1';
      const close = () => { modal.classList.add('hidden'); (window as any).__pendingForm = null; };
      modal.querySelectorAll<HTMLElement>('[data-confirm-cancel]').forEach(b => b.addEventListener('click', close));
      okBtn.addEventListener('click', () => {
        const form = (window as any).__pendingForm as HTMLFormElement | null;
        if (!form) return;
        const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        if (btn) { btn.disabled = true; btn.textContent = '✅ Enviando…'; }
        modal.classList.add('hidden');
        form.submit(); // envío nativo (no dispara el listener de confirmación)
      });
    }
  }

  function initSteppers() {
    document.querySelectorAll<HTMLButtonElement>('.stepper-btn').forEach(btn => {
      if (btn.dataset.stepInit) return;
      btn.dataset.stepInit = '1';
      btn.addEventListener('click', () => {
        const input = document.querySelector<HTMLInputElement>(`input[name="${btn.dataset.target}"]`);
        if (!input) return;
        const val = parseInt(input.value) || 0;
        const next = btn.dataset.action === 'inc' ? Math.min(val + 1, 20) : Math.max(val - 1, 0);
        input.value = String(next);
        input.dispatchEvent(new Event('input', { bubbles: true }));
      });
    });
  }

  // ── Borrador local: nunca perder lo tecleado ──────────────────────────────
  // Guarda cada marcador en localStorage al instante (keyed por match_id, estable
  // entre recargas). Si el envío falla, la BD cae, o el jugador navega y vuelve,
  // el formulario reaparece pre-llenado. Cuando un pick ya está en la BD (tarjeta
  // "✓ Guardado", marcada con data-saved-match) se borra del borrador. Es local al
  // dispositivo: justo lo que se quiere para "no perdí mis marcadores".
  const DRAFT_KEY = 'polla:pred-draft:v1';
  function loadDraft(): Record<string, any> {
    try { return JSON.parse(localStorage.getItem(DRAFT_KEY) || '{}') || {}; } catch { return {}; }
  }
  function saveDraft(d: Record<string, any>) {
    try { localStorage.setItem(DRAFT_KEY, JSON.stringify(d)); } catch { /* sin almacenamiento: no rompe */ }
  }

  function initDraft() {
    // 1. Limpiar del borrador los picks que YA están en la BD (leídos fresh al cargar).
    let draft = loadDraft();
    let changed = false;
    document.querySelectorAll<HTMLElement>('[data-saved-match]').forEach(el => {
      const id = el.dataset.savedMatch;
      if (id && draft[id]) { delete draft[id]; changed = true; }
    });
    if (changed) saveDraft(draft);

    const forms = document.querySelectorAll<HTMLFormElement>('form[action="/api/predictions/submit-jornada"]');
    forms.forEach(form => {
      const hiddens = form.querySelectorAll<HTMLInputElement>('input[name^="matchId_"]');

      // 2. Repoblar inputs vacíos (default "0") con lo que hubiera en el borrador.
      hiddens.forEach(h => {
        const idx = h.name.slice('matchId_'.length);
        const d = draft[h.value];
        if (!d) return;
        const set = (n: string, v: any) => {
          if (v == null || v === '') return;
          const el = form.querySelector<HTMLInputElement>(`input[name="${n}_${idx}"]`);
          if (el) { el.value = String(v); el.dispatchEvent(new Event('input', { bubbles: true })); }
        };
        set('home', d.h); set('away', d.a); set('pen_home', d.ph); set('pen_away', d.pa);
      });

      // 3. Guardar en cada cambio del formulario.
      if (form.dataset.draftBound) return;
      form.dataset.draftBound = '1';
      form.addEventListener('input', () => {
        const cur = loadDraft();
        form.querySelectorAll<HTMLInputElement>('input[name^="matchId_"]').forEach(h => {
          const idx = h.name.slice('matchId_'.length);
          const g = (n: string) => form.querySelector<HTMLInputElement>(`input[name="${n}_${idx}"]`)?.value ?? '';
          cur[h.value] = { h: g('home'), a: g('away'), ph: g('pen_home'), pa: g('pen_away') };
        });
        saveDraft(cur);
      });
    });
  }

  // ── Popup de resultado: cerrar / reintentar ──────────────────────────────
  function initResultModal() {
    const m = document.getElementById('result-modal');
    if (!m) return;
    // Limpiar de la URL los parámetros de resultado para que, al volver a la app
    // (p.ej. tras compartir por WhatsApp y reactivar la pestaña, que recarga la
    // página), NO reaparezca el popup. El modal ya está en el DOM: quitar los
    // parámetros no lo cierra, solo evita que el servidor lo vuelva a pintar.
    const url = new URL(location.href);
    let dirty = false;
    ['ok', 'code', 'error', 'info'].forEach((p) => {
      if (url.searchParams.has(p)) { url.searchParams.delete(p); dirty = true; }
    });
    if (dirty) history.replaceState({}, '', url.pathname + url.search);

    const close = () => m.remove();
    m.querySelectorAll<HTMLButtonElement>('[data-close-modal]').forEach(b => b.addEventListener('click', close));
    m.querySelectorAll<HTMLButtonElement>('[data-retry]').forEach(b => b.addEventListener('click', () => {
      close();
      // El borrador ya dejó los marcadores cargados; bajar al primer form abierto.
      document.querySelector('form[action="/api/predictions/submit-jornada"]')
        ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }));
  }

  // ── Popup de jornada cerrada (dos disparadores comparten el mismo modal) ──
  //  1) ENTRADA TARDÍA (servidor marca data-late-key): el jugador entra y hay una
  //     jornada cerrada que NO alcanzó a pronosticar → se muestra UNA sola vez
  //     (localStorage por jornada) y al pulsar Entendido queda en el log.
  //  2) CIERRE EN VIVO (lo dispara initCountdown): la jornada cierra mientras
  //     teclea → al pulsar Entendido recarga para ver el estado real.
  function initCierreModal() {
    const m = document.getElementById('cierre-modal');
    if (!m) return;
    // En beta/dev el popup se muestra SIEMPRE (para grabar el tutorial sin tener
    // que usar incógnito, que en Android bloquea la grabación). En prod real
    // (PUBLIC_BETA != true) respeta el "una sola vez" por navegador.
    const siempreMostrar = import.meta.env.PUBLIC_BETA === 'true';
    const key = m.dataset.lateKey || '';
    if (key && (siempreMostrar || !localStorage.getItem('cierreSeen:' + key))) m.classList.remove('hidden');

    const ok = document.getElementById('cierre-ok');
    if (ok && !ok.dataset.bound) {
      ok.dataset.bound = '1';
      ok.addEventListener('click', async () => {
        // Igual en entrada tardía y en cierre en vivo: registrar en el log, marcar
        // como visto y CERRAR el popup (dejar navegar). Nunca recarga: en dev el
        // beta-time mantiene la jornada "abierta" y la recarga reabría el popup.
        const k = m.dataset.lateKey || m.dataset.liveKey || '';
        try {
          await fetch('/api/profile/ack-cierre', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ key: k }),
          });
        } catch { /* el registro es best-effort */ }
        // Recordar el "visto" por jornada (entrada tardía o cierre en vivo) para
        // que NO reaparezca al recargar — clave en dev por el beta-time.
        if (k) { try { localStorage.setItem('cierreSeen:' + k, '1'); } catch { /* sin almacenamiento */ } }
        m.dataset.dismissed = '1'; // evita que el tick del contador lo reabra
        m.classList.add('hidden');
      });
    }
  }

  function init() {
    // Guard anti doble-binding: init() corre por la llamada directa Y por
    // astro:page-load (ambos sobre el MISMO DOM en la carga inicial). Marca el
    // contenedor; en una navegación Astro reemplaza el DOM (root nuevo sin marca)
    // y se vuelve a inicializar. Sin esto, los listeners se duplicaban y el
    // botón Compartir llamaba navigator.share dos veces → la 2ª caía a wa.me.
    const root = document.querySelector<HTMLElement>('[data-pred-root]');
    if (!root || root.dataset.inited === '1') return;
    root.dataset.inited = '1';

    initFlags();
    initSteppers();
    initPenaltySections();
    initShareButtons();
    initConfirmSubmit();
    initCountdown();
    initDraft();
    initResultModal();
    initCierreModal();
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>

<style>
  /* Entrada de los modales: el backdrop atenúa y la tarjeta entra con un leve
     overshoot (pop), el icono rebota un instante después. */
  .backdropIn { animation: backdropIn .22s ease both; }
  .modalIn    { animation: modalIn .30s cubic-bezier(.2,.9,.3,1.25) both; }
  .iconPop    { animation: iconPop .42s .08s cubic-bezier(.2,.9,.3,1.4) both; }

  @keyframes backdropIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes modalIn {
    from { opacity: 0; transform: translateY(10px) scale(.95); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes iconPop {
    0%   { opacity: 0; transform: scale(.4); }
    60%  { opacity: 1; transform: scale(1.12); }
    100% { transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .backdropIn, .modalIn, .iconPop { animation: none; }
  }
</style>
