---
import Layout from '@/layouts/Layout.astro';
import TeamName from '@/components/TeamName.astro';
import { supabase } from '@/lib/supabase';
import { betaNowMs } from '@/lib/betaTime';
import { boliviaDayStart, boliviaDayKey, jornadaLockState } from '@/lib/jornada';
import { fmtFecha } from '@/lib/fechas';
import { isoForTeam, spanishName } from '@/lib/isoFlags';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
if (!accessToken || !refreshToken) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: { user } } = await supabase.auth.setSession({
  access_token: accessToken,
  refresh_token: refreshToken,
});
if (!user) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const nowMs = betaNowMs();

const [
  { data: matches },
  { data: navProfile },
  { data: myPredictions },
  { data: startedMatchData },
  { data: mySanctions },
] = await Promise.all([
  supabase.from('matches').select('*').eq('is_finished', false).not('home_team', 'ilike', 'TBD%').not('away_team', 'ilike', 'TBD%').not('home_team', 'ilike', 'Winner%').not('away_team', 'ilike', 'Winner%').order('match_date', { ascending: true }),
  supabase.from('profiles').select('username, puntos_totales, es_referi, pago_70, pago_50, expulsado').eq('id', user.id).single(),
  supabase.from('predictions').select('match_id, user_home, user_away, user_home_pen, user_away_pen, user_winner_penalties').eq('user_id', user.id),
  supabase.from('matches').select('match_date, is_finished').lte('match_date', new Date(nowMs).toISOString()),
  supabase.from('sanctions').select('type, created_at').eq('user_id', user.id).in('type', ['red', 'double_red']).eq('active', true),
]);

const predMap = new Map(myPredictions?.map(p => [p.match_id, p]) ?? []);

// Bloqueo por sanción: el expulsado (doble roja) no pronostica nunca; una roja
// anula la jornada de su día Bolivia (frontera 03:00 BOT), igual que en scoring.
const isExpulsado = navProfile?.expulsado === true;
const sanctionedDayTimes = new Set(
  (mySanctions ?? []).map(s => boliviaDayStart(new Date(s.created_at).getTime()).getTime())
);
function isSanctioned(jornadaMatches: MatchRow[]): boolean {
  if (isExpulsado) return true;
  const firstTime = Math.min(...jornadaMatches.map(m => new Date(m.match_date).getTime()));
  return sanctionedDayTimes.has(boliviaDayStart(firstTime).getTime());
}

function formatTime(dateStr: string): string {
  return fmtFecha(dateStr, {
    hour: '2-digit', minute: '2-digit',
  });
}
function formatShortDate(dateStr: string): string {
  return fmtFecha(dateStr, {
    weekday: 'short', day: 'numeric', month: 'short',
  });
}


type MatchRow = {
  id: string;
  home_team: string;
  away_team: string;
  match_date: string;
  stage: string;
  group_name: string | null;
  round: string | null;
  jornada: string | null;
};

// Agrupar por jornada Bolivia — el día empieza a las 03:00 AM BOT para que
// partidos de medianoche (00:00-02:59) queden con la noche anterior.
const grouped = new Map<string, MatchRow[]>();
for (const m of (matches ?? []) as MatchRow[]) {
  const dayStart = boliviaDayStart(new Date(m.match_date).getTime());
  const key = fmtFecha(dayStart, {
    weekday: 'long', day: 'numeric', month: 'long',
  });
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(m);
}

const now = nowMs;

// Días jornada (clave 03:00 BOT) que ya tuvieron al menos un partido iniciado
const daysWithStartedMatch = new Set(
  (startedMatchData ?? []).map(m => boliviaDayKey(new Date(m.match_date).getTime()))
);
// Hay algún partido en curso ahora mismo (started + unfinished)
const hasMatchInProgress = (startedMatchData ?? []).some(m => !m.is_finished);

// Estado de bloqueo de la jornada (lógica única en lib/jornada.ts).
function lockStateFor(jornadaMatches: MatchRow[]) {
  const firstMatchMs = Math.min(...jornadaMatches.map(m => new Date(m.match_date).getTime()));
  return jornadaLockState({
    firstMatchMs,
    nowMs: now,
    sameDayStarted: daysWithStartedMatch.has(boliviaDayKey(firstMatchMs)),
    hasMatchInProgress,
    hasEarlierUnfinished: (matches ?? []).some(m => new Date(m.match_date).getTime() < firstMatchMs),
  });
}

function buildShareData(dayMatches: MatchRow[], username: string) {
  const firstMatch = dayMatches[0];
  const cutoff = new Date(new Date(firstMatch.match_date).getTime() - 2 * 3600 * 1000);
  const cutoffStr = fmtFecha(cutoff, { hour: '2-digit', minute: '2-digit' });
  const items = dayMatches
    .filter(m => predMap.has(m.id))
    .map(m => {
      const pred = predMap.get(m.id)!;
      return {
        home: spanishName(m.home_team), away: spanishName(m.away_team),
        homeISO: isoForTeam(m.home_team),
        awayISO: isoForTeam(m.away_team),
        uh: pred.user_home, ua: pred.user_away,
        uhp: pred.user_home_pen ?? null, uap: pred.user_away_pen ?? null,
        pen: pred.user_winner_penalties ?? null,
      };
    });
  return JSON.stringify({ username, cutoff: cutoffStr, items });
}

const errorParam = Astro.url.searchParams.get('error');
const infoParam  = Astro.url.searchParams.get('info');
const okParam    = Astro.url.searchParams.get('ok');

// ── Verificación ACTIVA contra la BD ──────────────────────────────────────────
// submit-jornada devuelve los match_id que insertó. Aquí se confirma que esos id
// REALMENTE están en `predictions` (predMap viene de leer la BD recién). Si la
// cuenta no cuadra, algo no se guardó → se avisa en rojo (esto es lo que faltó
// en el caso Niels). El '1' es compatibilidad con envíos viejos.
const okIds = (okParam && okParam !== '1') ? okParam.split(',').filter(Boolean) : [];
const okVerified = okIds.filter((id) => predMap.has(id));
const okAllSaved = okIds.length > 0 && okVerified.length === okIds.length;

// Contador global de inputs — evita colisiones de nombre entre jornadas distintas
let globalFormIdx = 0;
---

<Layout title="Pronósticos" navProfile={navProfile} isAuthed={true}>
  <div class="space-y-6">

    <div class="flex items-center justify-between gap-2">
      <h1 class="font-display text-4xl text-white tracking-wide">MIS PRONÓSTICOS</h1>
      <a href="/reglas" class="text-xs text-slate-500 active:text-gold transition py-2 px-1">Reglamento →</a>
    </div>

    {import.meta.env.PUBLIC_BETA !== "true" && !(navProfile?.pago_70 && navProfile?.pago_50) && (
      <div class="bg-brand-900 border border-amber-500/40 rounded-2xl p-8 text-center space-y-3">
        <div class="text-4xl">🔒</div>
        <h2 class="text-white font-bold text-lg">Pronósticos bloqueados</h2>
        <p class="text-slate-400 text-sm max-w-sm mx-auto">
          Para participar debés tener los dos pagos confirmados: <strong class="text-amber-400">70 Bs + 50 Bs</strong>.
          Una vez confirmado por el Réferi, se habilitarán tus pronósticos.
        </p>
        <p class="text-xs text-slate-600 mt-2">¿Ya pagaste? Contactá al Réferi.</p>
      </div>
    )}

    {/* ── Rechazos: NO SE GUARDÓ (prominente, imposible de ignorar) ── */}
    {errorParam && errorParam !== 'incompleto' && (
      <div class="bg-fifared/20 border-2 border-fifared/60 rounded-2xl px-4 py-4 text-center space-y-1">
        <div class="text-3xl">⚠️</div>
        <p class="text-red-200 font-bold text-base">Tus pronósticos NO se guardaron</p>
        <p class="text-red-300/90 text-sm">
          {errorParam === 'cerrado'
            ? '🔒 La jornada ya está cerrada.'
            : errorParam === 'en_curso'
            ? '⏳ El partido ya empezó. Las apuestas para esta jornada están cerradas.'
            : decodeURIComponent(errorParam)}
        </p>
        <p class="text-xs text-red-300/70">Verifica abajo: si no ves "✓ Guardado", no quedó registrado.</p>
      </div>
    )}
    {errorParam === 'incompleto' && (
      <div class="bg-fifared/15 border border-fifared/40 rounded-xl px-4 py-3 text-sm text-red-300 text-center">
        ⚠️ Completa el marcador de todos los partidos antes de enviar.
      </div>
    )}
    {infoParam === 'ya_pronosticado' && (
      <div class="bg-brand-700/40 border border-brand-600 rounded-xl px-4 py-3 text-sm text-slate-300 text-center">
        Ya registraste pronósticos para esa jornada.
      </div>
    )}

    {/* ── Verificación activa contra la BD ── */}
    {okIds.length > 0 && okAllSaved && (
      <div class="bg-gol/15 border-2 border-gol/50 rounded-2xl px-4 py-4 text-center space-y-1">
        <div class="text-3xl">✅</div>
        <p class="text-green-200 font-bold text-base">Verificado en la base de datos</p>
        <p class="text-green-300/90 text-sm">{okVerified.length} de {okIds.length} pronóstico{okIds.length !== 1 ? 's' : ''} guardado{okIds.length !== 1 ? 's' : ''} ✓</p>
      </div>
    )}
    {okIds.length > 0 && !okAllSaved && (
      <div class="bg-fifared/20 border-2 border-fifared/60 rounded-2xl px-4 py-4 text-center space-y-1">
        <div class="text-3xl">⚠️</div>
        <p class="text-red-200 font-bold text-base">¡Atención! No se guardó todo</p>
        <p class="text-red-300/90 text-sm">Solo {okVerified.length} de {okIds.length} quedaron en la base. <strong>Reintenta los que falten.</strong></p>
      </div>
    )}
    {okParam === '1' && (
      <div class="bg-gol/10 border border-gol/30 rounded-xl px-4 py-3 text-sm text-green-300 text-center">
        ✅ Pronósticos enviados correctamente.
      </div>
    )}

    {(import.meta.env.PUBLIC_BETA === 'true' || (navProfile?.pago_70 && navProfile?.pago_50)) && grouped.size === 0 && (
      <div class="text-center py-20 text-slate-600">
        <div class="text-5xl mb-4">📅</div>
        <p class="text-base">No hay partidos disponibles por el momento.</p>
      </div>
    )}

    {(import.meta.env.PUBLIC_BETA === 'true' || (navProfile?.pago_70 && navProfile?.pago_50)) && [...grouped.entries()].map(([jornadaKey, jornadaMatches]) => {
      const sanctioned = isSanctioned(jornadaMatches);
      const lockState = lockStateFor(jornadaMatches);
      const closed = lockState === 'closed';
      const prevPending = lockState === 'prevPending';
      const ongoingLock = lockState === 'ongoingLock';
      const predCount = jornadaMatches.filter(m => predMap.has(m.id)).length;
      const allDone = predCount === jornadaMatches.length;
      const hasSome = predCount > 0;
      const firstTime = Math.min(...jornadaMatches.map(m => new Date(m.match_date).getTime()));
      const cutoffStr = fmtFecha(firstTime - 2 * 3600 * 1000, {
        weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit',
      });
      const shareData = buildShareData(jornadaMatches, navProfile?.username ?? 'yo');

      return (
        <div class="space-y-3" data-jornada>

          {/* ── Encabezado de jornada ── */}
          <div class={`flex items-center justify-between px-4 py-3 rounded-xl border ${
            sanctioned   ? 'bg-fifared/12 border-fifared/40' :
            prevPending  ? 'bg-brand-900 border-brand-700/40' :
            ongoingLock  ? 'bg-amber-900/10 border-amber-500/30' :
            closed       ? 'bg-fifared/8 border-fifared/30' :
            allDone      ? 'bg-gol/8 border-gol/30' :
                           'bg-brand-800/60 border-brand-700/60'
          }`}>
            <div>
              <h2 class={`font-display text-xl tracking-wide capitalize ${prevPending ? 'text-slate-500' : 'text-white'}`}>{jornadaKey}</h2>
              <p class={`text-xs mt-0.5 ${sanctioned ? 'text-fifared' : prevPending ? 'text-slate-600' : ongoingLock ? 'text-amber-400' : closed ? 'text-fifared' : 'text-slate-500'}`}>
                {sanctioned
                  ? (isExpulsado ? '🟥🟥 Expulsado — no puedes pronosticar' : '🟥 Jornada anulada por tarjeta roja')
                  : prevPending
                  ? '🔒 Disponible cuando terminen los partidos anteriores'
                  : ongoingLock
                  ? '⏳ Esperá que termine el partido de hoy'
                  : closed
                  ? '🔒 Cerrada'
                  : <span class="cutoff-cd font-semibold" data-cutoff={firstTime - 2 * 3600 * 1000}>⏰ Cierre: {cutoffStr}</span>
                }
              </p>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
              <span class={`text-xs px-2 py-1 rounded-full border ${
                sanctioned ? 'text-fifared border-fifared/40 bg-fifared/15' :
                allDone    ? 'text-gol border-gol/30 bg-gol/10' :
                hasSome    ? 'text-amarilla border-amarilla/30 bg-amarilla/10' :
                prevPending ? 'text-slate-600 border-brand-700/40 bg-brand-800/40' :
                closed     ? 'text-fifared border-fifared/30 bg-fifared/10' :
                              'text-slate-500 border-brand-600 bg-brand-700/30'
              }`}>
                {sanctioned
                  ? '🟥 Anulada'
                  : allDone
                  ? '✅ Completa'
                  : hasSome
                  ? `${predCount}/${jornadaMatches.length}`
                  : prevPending
                  ? '⏳ Jornada anterior abierta'
                  : ongoingLock
                  ? '⏳ Partido en curso'
                  : closed
                  ? '🔒 Cerrada sin pronóstico'
                  : `0/${jornadaMatches.length}`}
              </span>
              {hasSome && (
                <button
                  class="share-btn flex items-center gap-1.5 text-xs font-semibold text-[#25D366] bg-[#25D366]/10 border border-[#25D366]/30 px-3 py-2 rounded-xl transition active:bg-[#25D366]/20 min-h-[44px]"
                  data-share={shareData}>
                  <svg viewBox="0 0 24 24" class="w-4 h-4 flex-shrink-0" fill="currentColor" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  <span>Compartir</span>
                </button>
              )}
            </div>
          </div>

          {/* ── Si la jornada está abierta y hay partidos sin pronosticar: form inline ── */}
          {!sanctioned && !closed && !prevPending && !ongoingLock && !allDone ? (
            <form method="POST" action="/api/predictions/submit-jornada" class="space-y-2">

              {jornadaMatches.map((m) => {
                const existing = predMap.get(m.id);
                const idx = existing ? -1 : globalFormIdx++;
                const isKnockout = m.stage === 'knockout';

                return (
                  <div class={`bg-brand-900 border rounded-2xl p-4 ${existing ? 'border-gol/30 bg-gol/5' : 'border-brand-700/60'}`}>

                    {/* Fecha + etiqueta */}
                    <div class="flex items-center justify-between mb-3">
                      <span class="text-slate-400 font-medium text-xs">
                        {m.stage === 'group' ? (m.group_name ? `Grupo ${m.group_name}` : m.jornada) : m.round}
                      </span>
                      <div class="text-right">
                        <p class="text-xs text-slate-500">{formatShortDate(m.match_date)}</p>
                        <p class="font-display text-base font-bold text-gold leading-tight">{formatTime(m.match_date)}</p>
                      </div>
                    </div>

                    {/* Equipos + inputs */}
                    {existing ? (
                      /* Ya pronosticado: layout horizontal clásico */
                      <Fragment>
                      <div class="flex items-center gap-2">
                        <div class="flex-1 min-w-0">
                          <TeamName team={m.home_team} side="home" class="text-white font-semibold text-base" />
                        </div>
                        <span class="text-gol font-display text-3xl flex-shrink-0 px-2">
                          {existing.user_home}–{existing.user_away}
                        </span>
                        <div class="flex-1 min-w-0">
                          <TeamName team={m.away_team} side="away" class="text-white font-semibold text-base" />
                        </div>
                      </div>
                      <p class="text-center mt-2.5">
                        <span class="text-[11px] font-semibold text-gol bg-gol/10 border border-gol/30 rounded-full px-2.5 py-1">✓ Guardado {existing.user_home}–{existing.user_away}</span>
                      </p>
                      </Fragment>
                    ) : (
                      /* Sin pronóstico: nombres arriba, steppers abajo */
                      <div class="space-y-3">
                        <input type="hidden" name={`matchId_${idx}`} value={m.id} />
                        <div class="flex items-center justify-between gap-2">
                          <div class="flex-1 min-w-0">
                            <TeamName team={m.home_team} side="home" class="text-white font-semibold text-base" />
                          </div>
                          <span class="text-slate-600 text-sm flex-shrink-0">vs</span>
                          <div class="flex-1 min-w-0">
                            <TeamName team={m.away_team} side="away" class="text-white font-semibold text-base" />
                          </div>
                        </div>
                        <div class="flex items-center justify-center gap-2">
                          {/* Stepper local */}
                          <div class="flex items-center gap-1">
                            <button type="button"
                              class="stepper-btn w-10 h-10 rounded-xl bg-brand-700 active:bg-brand-600 text-white text-xl font-bold flex items-center justify-center transition touch-manipulation select-none"
                              data-action="dec" data-target={`home_${idx}`}>−</button>
                            <input
                              type="number" inputmode="numeric" pattern="[0-9]*"
                              name={`home_${idx}`}
                              min="0" max="20" required value="0"
                              data-team={spanishName(m.home_team)}
                              class="w-14 bg-brand-800 border-2 border-brand-700 rounded-xl py-2 text-white text-2xl font-display text-center focus:outline-none focus:border-gold transition"
                            />
                            <button type="button"
                              class="stepper-btn w-10 h-10 rounded-xl bg-brand-700 active:bg-brand-600 text-white text-xl font-bold flex items-center justify-center transition touch-manipulation select-none"
                              data-action="inc" data-target={`home_${idx}`}>+</button>
                          </div>
                          <span class="text-slate-500 font-bold text-xl px-1">–</span>
                          {/* Stepper visitante */}
                          <div class="flex items-center gap-1">
                            <button type="button"
                              class="stepper-btn w-10 h-10 rounded-xl bg-brand-700 active:bg-brand-600 text-white text-xl font-bold flex items-center justify-center transition touch-manipulation select-none"
                              data-action="dec" data-target={`away_${idx}`}>−</button>
                            <input
                              type="number" inputmode="numeric" pattern="[0-9]*"
                              name={`away_${idx}`}
                              min="0" max="20" required value="0"
                              data-team={spanishName(m.away_team)}
                              class="w-14 bg-brand-800 border-2 border-brand-700 rounded-xl py-2 text-white text-2xl font-display text-center focus:outline-none focus:border-gold transition"
                            />
                            <button type="button"
                              class="stepper-btn w-10 h-10 rounded-xl bg-brand-700 active:bg-brand-600 text-white text-xl font-bold flex items-center justify-center transition touch-manipulation select-none"
                              data-action="inc" data-target={`away_${idx}`}>+</button>
                          </div>
                        </div>
                      </div>
                    )}

                    {/* Penales (knockout sin pronóstico) */}
                    {isKnockout && !existing && (
                      <div
                        class="hidden mt-3 pt-3 border-t border-brand-800 space-y-2"
                        data-pen-section={`pen-section-${idx}`}
                      >
                        <p class="text-xs text-gold text-center font-semibold">⚡ Score en penales <span class="text-slate-500 font-normal">(solo si hay empate)</span></p>
                        <div class="flex items-center gap-2">
                          <div class="flex-1 text-center space-y-1">
                            <span class="text-xs text-slate-500 block truncate">{spanishName(m.home_team)}</span>
                            <input
                              type="number"
                              inputmode="numeric"
                              pattern="[0-9]*"
                              name={`pen_home_${idx}`}
                              min="0" max="20" placeholder="0"
                              class="w-full bg-gold/10 border-2 border-gold/40 rounded-xl py-3 text-gold text-2xl font-display text-center focus:outline-none focus:border-gold transition placeholder:text-gold/30"
                              data-pen-input={`pen-section-${idx}`}
                            />
                          </div>
                          <span class="text-gold/40 font-bold text-xl flex-shrink-0">–</span>
                          <div class="flex-1 text-center space-y-1">
                            <span class="text-xs text-slate-500 block truncate">{spanishName(m.away_team)}</span>
                            <input
                              type="number"
                              inputmode="numeric"
                              pattern="[0-9]*"
                              name={`pen_away_${idx}`}
                              min="0" max="20" placeholder="0"
                              class="w-full bg-gold/10 border-2 border-gold/40 rounded-xl py-3 text-gold text-2xl font-display text-center focus:outline-none focus:border-gold transition placeholder:text-gold/30"
                              data-pen-input={`pen-section-${idx}`}
                            />
                          </div>
                        </div>
                        <p class="text-xs text-slate-600 text-center">El ganador en penales se determina automáticamente</p>
                      </div>
                    )}

                    {/* Ya pronosticado: mostrar score de penales si aplica */}
                    {existing && (existing.user_home_pen !== null || existing.user_winner_penalties) && (
                      <p class="text-xs text-slate-500 text-center mt-2">
                        Penales: <span class="text-gold">
                          {existing.user_home_pen !== null
                            ? `${existing.user_home_pen} – ${existing.user_away_pen}`
                            : existing.user_winner_penalties === 'home' ? spanishName(m.home_team) : spanishName(m.away_team)
                          }
                        </span>
                      </p>
                    )}
                  </div>
                );
              })}

              <button type="submit"
                class="w-full bg-gold text-brand-950 font-bold py-4 rounded-2xl transition active:bg-gold-dark text-base min-h-[52px] mt-1">
                Enviar pronósticos de la jornada ✅
              </button>
              <p class="text-xs text-slate-600 text-center pb-1">
                Tolerancia Cero — una vez enviado no se puede modificar.
              </p>
            </form>

          ) : (
            /* ── Jornada cerrada o completa: solo lectura ── */
            <div class="space-y-2">
              {jornadaMatches.map((m) => {
                const existing = predMap.get(m.id);
                return (
                  <div class={`bg-brand-900 border rounded-2xl p-4 ${existing ? 'border-gol/30 bg-gol/5' : prevPending ? 'border-brand-700/40 bg-brand-800/30' : 'border-fifared/30 bg-fifared/5'}`}>
                    <div class="flex items-center justify-between mb-2">
                      <span class="text-slate-400 font-medium text-xs">
                        {m.stage === 'group' ? (m.group_name ? `Grupo ${m.group_name}` : m.jornada) : m.round}
                      </span>
                      <div class="text-right">
                        <p class="text-xs text-slate-500">{formatShortDate(m.match_date)}</p>
                        <p class="font-display text-base font-bold text-gold leading-tight">{formatTime(m.match_date)}</p>
                      </div>
                    </div>
                    <div class="flex items-center gap-2">
                      <div class="flex-1 min-w-0">
                        <TeamName team={m.home_team} side="home" class={`font-semibold text-base ${existing ? 'text-white' : 'text-slate-400'}`} />
                      </div>
                      <div class="flex-shrink-0 px-2 text-center min-w-[60px]">
                        {existing
                          ? <span class="text-gol font-display text-2xl">{existing.user_home}–{existing.user_away}</span>
                          : <span class="text-slate-700 font-bold text-xl">–</span>
                        }
                      </div>
                      <div class="flex-1 min-w-0">
                        <TeamName team={m.away_team} side="away" class={`font-semibold text-base ${existing ? 'text-white' : 'text-slate-400'}`} />
                      </div>
                    </div>
                    {existing && (existing.user_home_pen !== null || existing.user_winner_penalties) && (
                      <p class="text-xs text-slate-500 text-center mt-1.5">
                        Penales: <span class="text-gold">
                          {existing.user_home_pen !== null
                            ? `${existing.user_home_pen} – ${existing.user_away_pen}`
                            : existing.user_winner_penalties === 'home' ? spanishName(m.home_team) : spanishName(m.away_team)
                          }
                        </span>
                      </p>
                    )}
                    {!existing && (
                      <button disabled class={`w-full mt-2 flex items-center justify-center gap-2 text-sm rounded-xl py-3 cursor-not-allowed opacity-75 ${sanctioned ? 'text-fifared bg-fifared/10 border border-fifared/40' : 'text-slate-300 bg-brand-800/50 border border-brand-700/50'}`}>
                        {sanctioned
                          ? (isExpulsado ? '🟥🟥 Expulsado, sin pronóstico' : '🟥 Jornada anulada por tarjeta roja')
                          : prevPending
                          ? '⏳ Espera que terminen los partidos anteriores'
                          : ongoingLock
                          ? '⏳ El partido ya comenzó, sin pronóstico'
                          : '🔒 Jornada cerrada, sin pronóstico'}
                      </button>
                    )}
                  </div>
                );
              })}
            </div>
          )}

        </div>
      );
    })}
  </div>

  {/* ── Modal de confirmación antes de enviar ── */}
  <div id="confirm-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-confirm-cancel></div>
    <div class="relative bg-brand-900 border border-brand-700 rounded-2xl p-5 w-full max-w-sm space-y-4 shadow-2xl">
      <div class="text-center space-y-1">
        <h3 class="font-display text-xl text-white">¿Confirmar envío?</h3>
        <p class="text-xs text-slate-500">Revisa tus marcadores. Una vez enviado no se puede cambiar.</p>
      </div>
      <div id="confirm-list" class="space-y-1.5 max-h-[45vh] overflow-y-auto"></div>
      <div class="flex gap-2 pt-1">
        <button type="button" data-confirm-cancel class="flex-1 bg-brand-800 border border-brand-700 text-slate-300 font-semibold py-3 rounded-xl active:bg-brand-700 transition min-h-[48px]">Volver</button>
        <button type="button" id="confirm-ok" class="flex-1 bg-gold text-brand-950 font-bold py-3 rounded-xl active:bg-gold-dark transition min-h-[48px]">Confirmar ✅</button>
      </div>
    </div>
  </div>
</Layout>

<script>
  async function copyText(text: string): Promise<boolean> {
    try { await navigator.clipboard.writeText(text); return true; } catch { /* fallback */ }
    // Fallback síncrono (Firefox / permiso denegado): textarea + execCommand durante el click
    try {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.setAttribute('readonly', '');
      ta.style.cssText = 'position:fixed;top:0;left:0;opacity:0';
      document.body.appendChild(ta);
      ta.focus(); ta.select();
      const ok = (document as any).execCommand('copy'); // fallback legacy (Firefox)
      ta.remove();
      return ok;
    } catch { return false; }
  }

  async function waShare(text: string) {
    // Mobile: compartir nativo (app WhatsApp) o wa.me directo
    if (/Android|iPhone|iPad|iPod/i.test(navigator.userAgent)) {
      if (navigator.share) {
        try { await navigator.share({ text }); return; } catch (e) {
          if ((e as Error).name === 'AbortError') return; // usuario canceló
        }
      }
      window.open('https://wa.me/?text=' + encodeURIComponent(text), '_blank');
      return;
    }
    // Desktop: SIEMPRE copiar. Nunca abrir WhatsApp web (mangla emojis y salen rombos).
    const copied = await copyText(text);
    if (!copied) return;
    const el = document.createElement('div');
    el.textContent = '\uD83D\uDCCB Copiado \u2014 peg\u00e1lo en WhatsApp con Ctrl+V';
    el.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0d1117;border:1px solid #25d366;color:#fff;padding:12px 20px;border-radius:12px;font-size:14px;z-index:9999;pointer-events:none;white-space:nowrap';
    document.body.appendChild(el);
    setTimeout(() => { el.style.transition = 'opacity .3s'; el.style.opacity = '0'; setTimeout(() => el.remove(), 300); }, 3500);
  }

  // Generar emojis de bandera en runtime
  function flagFromISO(cc: string): string {
    const base = 0x1F1E6 - 65;
    return String.fromCodePoint(cc.charCodeAt(0) + base, cc.charCodeAt(1) + base);
  }

  function initFlags() {
    document.querySelectorAll<HTMLSpanElement>('.flag-emoji').forEach(el => {
      const iso = el.dataset.iso;
      if (iso) el.textContent = flagFromISO(iso);
    });
  }

  // Mostrar selector de penales en partidos de knockout cuando hay empate
  function initPenaltySections() {
    document.querySelectorAll<HTMLInputElement>('input[type="number"]').forEach(input => {
      const name = input.name; // home_N o away_N
      const match = name.match(/^(home|away)_(\d+)$/);
      if (!match) return;
      const idx = match[2];
      const section = document.querySelector<HTMLElement>(`[data-pen-section="pen-section-${idx}"]`);
      if (!section) return;

      function check() {
        const homeVal = (document.querySelector<HTMLInputElement>(`input[name="home_${idx}"]`))?.value;
        const awayVal = (document.querySelector<HTMLInputElement>(`input[name="away_${idx}"]`))?.value;
        const h = parseInt(homeVal ?? '');
        const a = parseInt(awayVal ?? '');
        if (!isNaN(h) && !isNaN(a) && h === a) {
          section!.classList.remove('hidden');
        } else {
          section!.classList.add('hidden');
          section!.querySelectorAll<HTMLInputElement>('input[type="number"]').forEach(r => { r.value = ''; });
        }
      }
      input.addEventListener('input', check);
    });
  }

  // WhatsApp share
  function buildText(data: {
    username: string; cutoff: string;
    items: Array<{ home: string; away: string; homeISO: string; awayISO: string; uh: number; ua: number; uhp: number|null; uap: number|null; pen: string | null }>;
  }) {
    const lines = [
      `\u26BD *Pron\u00f3sticos de ${data.username}*`,
      `_Cierre: ${data.cutoff}_`,
      '',
    ];
    data.items.forEach(item => {
      const hf = item.homeISO ? flagFromISO(item.homeISO) : '';
      const af = item.awayISO ? flagFromISO(item.awayISO) : '';
      lines.push(`${item.home} ${hf} ${item.uh}\u2013${item.ua} ${af} ${item.away}`);
      if (item.pen) {
        const wf    = item.pen === 'home' ? hf : af;
        const wName = item.pen === 'home' ? item.home : item.away;
        const penScore = item.uhp !== null ? `${item.uhp}\u2013${item.uap} pen \u00B7 ` : '';
        lines.push(`_(${penScore}clasifica ${wf} ${wName})_`);
      }
      lines.push('');
    });
    lines.push(`_Polla Mundial 2026_ \uD83C\uDFC6`);
    return lines.join('\n');
  }

  function initShareButtons() {
    document.querySelectorAll<HTMLButtonElement>('.share-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const data = JSON.parse(btn.dataset.share ?? '{}');
        waShare(buildText(data));
      });
    });
  }

  // ── Contador en vivo del cierre (verde > 1h, ámbar < 1h, rojo al cerrar) ──
  function fmtRemaining(ms: number): string {
    const t = Math.floor(ms / 1000);
    const h = Math.floor(t / 3600);
    const m = Math.floor((t % 3600) / 60);
    const s = t % 60;
    if (h > 0) return `${h}h ${m}m`;
    if (m > 0) return `${m}m ${s}s`;
    return `${s}s`;
  }

  function initCountdown() {
    if ((window as any).__cdInterval) clearInterval((window as any).__cdInterval);
    const els = Array.from(document.querySelectorAll<HTMLElement>('.cutoff-cd'));
    if (!els.length) return;
    const tick = () => {
      els.forEach(cd => {
        const cutoff = parseInt(cd.dataset.cutoff || '0', 10);
        const rem = cutoff - Date.now();
        if (rem <= 0) {
          cd.textContent = '🔒 CERRADA';
          cd.style.color = '#f87171';
          const wrap = cd.closest('[data-jornada]');
          const btn = wrap?.querySelector<HTMLButtonElement>('button[type="submit"]');
          if (btn && !btn.disabled) {
            btn.disabled = true;
            btn.textContent = '🔒 Jornada cerrada';
            btn.classList.add('opacity-60', 'cursor-not-allowed');
          }
          return;
        }
        cd.textContent = '⏰ Cierra en ' + fmtRemaining(rem);
        cd.style.color = rem > 3600000 ? '#4ade80' : rem > 600000 ? '#fbbf24' : '#f87171';
      });
    };
    tick();
    (window as any).__cdInterval = setInterval(tick, 1000);
  }

  // ── Confirmación antes de enviar ──
  function summaryRows(form: HTMLFormElement) {
    const rows: { home: string; away: string; hs: string; as: string; pen: string }[] = [];
    form.querySelectorAll<HTMLInputElement>('input[name^="home_"]').forEach(hi => {
      const idx = hi.name.slice(5);
      const ai = form.querySelector<HTMLInputElement>(`input[name="away_${idx}"]`);
      if (!ai) return;
      const ph = form.querySelector<HTMLInputElement>(`input[name="pen_home_${idx}"]`);
      const pa = form.querySelector<HTMLInputElement>(`input[name="pen_away_${idx}"]`);
      let pen = '';
      if (ph && pa && ph.value !== '' && pa.value !== '') pen = ` · pen ${ph.value}–${pa.value}`;
      rows.push({ home: hi.dataset.team || '', away: ai.dataset.team || '', hs: hi.value, as: ai.value, pen });
    });
    return rows;
  }

  function initConfirmSubmit() {
    const modal = document.getElementById('confirm-modal');
    const list = document.getElementById('confirm-list');
    const okBtn = document.getElementById('confirm-ok');
    if (!modal || !list || !okBtn) return;

    document.querySelectorAll<HTMLFormElement>('form[action="/api/predictions/submit-jornada"]').forEach(form => {
      if (form.dataset.confirmBound) return;
      form.dataset.confirmBound = '1';
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const rows = summaryRows(form);
        list.innerHTML = rows.map(r =>
          `<div class="flex items-center justify-between gap-2 bg-brand-800/50 rounded-lg px-3 py-2">
             <span class="text-sm text-slate-300 truncate">${r.home} <span class="text-slate-600">vs</span> ${r.away}</span>
             <span class="font-display text-lg text-gold flex-shrink-0">${r.hs}–${r.as}<span class="text-[10px] text-slate-400">${r.pen}</span></span>
           </div>`).join('');
        (window as any).__pendingForm = form;
        modal.classList.remove('hidden');
      });
    });

    if (!okBtn.dataset.bound) {
      okBtn.dataset.bound = '1';
      const close = () => { modal.classList.add('hidden'); (window as any).__pendingForm = null; };
      modal.querySelectorAll<HTMLElement>('[data-confirm-cancel]').forEach(b => b.addEventListener('click', close));
      okBtn.addEventListener('click', () => {
        const form = (window as any).__pendingForm as HTMLFormElement | null;
        if (!form) return;
        const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        if (btn) { btn.disabled = true; btn.textContent = '✅ Enviando…'; }
        modal.classList.add('hidden');
        form.submit(); // envío nativo (no dispara el listener de confirmación)
      });
    }
  }

  function initSteppers() {
    document.querySelectorAll<HTMLButtonElement>('.stepper-btn').forEach(btn => {
      if (btn.dataset.stepInit) return;
      btn.dataset.stepInit = '1';
      btn.addEventListener('click', () => {
        const input = document.querySelector<HTMLInputElement>(`input[name="${btn.dataset.target}"]`);
        if (!input) return;
        const val = parseInt(input.value) || 0;
        const next = btn.dataset.action === 'inc' ? Math.min(val + 1, 20) : Math.max(val - 1, 0);
        input.value = String(next);
        input.dispatchEvent(new Event('input', { bubbles: true }));
      });
    });
  }

  function init() {
    initFlags();
    initSteppers();
    initPenaltySections();
    initShareButtons();
    initConfirmSubmit();
    initCountdown();
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
