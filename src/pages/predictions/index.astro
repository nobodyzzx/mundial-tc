---
import Layout from '@/layouts/Layout.astro';
import TeamName from '@/components/TeamName.astro';
import CerradaBar from '@/components/CerradaBar.astro';
import { createRequestClient } from '@/lib/supabase';
import { betaNowMs } from '@/lib/betaTime';
import { boliviaDayStart, boliviaDayKey, jornadaLockState, countsUnresolved } from '@/lib/jornada';
import { fmtFecha } from '@/lib/fechas';
import { isoForTeam, spanishName } from '@/lib/isoFlags';
import { logEvent } from '@/lib/system-log';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
if (!accessToken || !refreshToken) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const supabase = createRequestClient(); // sesión aislada por petición (ver lib/supabase)
const { data: { user } } = await supabase.auth.setSession({
  access_token: accessToken,
  refresh_token: refreshToken,
});
if (!user) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const nowMs = betaNowMs();

const [
  { data: matches },
  { data: navProfile },
  { data: myPredictions },
  { data: startedMatchData },
  { data: mySanctions },
] = await Promise.all([
  supabase.from('matches').select('*').eq('is_finished', false).not('home_team', 'ilike', 'TBD%').not('away_team', 'ilike', 'TBD%').not('home_team', 'ilike', 'Winner%').not('away_team', 'ilike', 'Winner%').order('match_date', { ascending: true }),
  supabase.from('profiles').select('username, puntos_totales, es_referi, pago_70, pago_50, expulsado').eq('id', user.id).single(),
  supabase.from('predictions').select('match_id, user_home, user_away, user_home_pen, user_away_pen, user_winner_penalties, created_at').eq('user_id', user.id),
  supabase.from('matches').select('match_date, is_finished').lte('match_date', new Date(nowMs).toISOString()),
  supabase.from('sanctions').select('type, created_at').eq('user_id', user.id).in('type', ['red', 'double_red']).eq('active', true),
]);

const predMap = new Map(myPredictions?.map(p => [p.match_id, p]) ?? []);

// Bloqueo por sanción: el expulsado (doble roja) no pronostica nunca; una roja
// anula la jornada de su día Bolivia (frontera 03:00 BOT), igual que en scoring.
const isExpulsado = navProfile?.expulsado === true;
const sanctionedDayTimes = new Set(
  (mySanctions ?? []).map(s => boliviaDayStart(new Date(s.created_at).getTime()).getTime())
);
function isSanctioned(jornadaMatches: MatchRow[]): boolean {
  if (isExpulsado) return true;
  const firstTime = Math.min(...jornadaMatches.map(m => new Date(m.match_date).getTime()));
  return sanctionedDayTimes.has(boliviaDayStart(firstTime).getTime());
}

function formatTime(dateStr: string): string {
  return fmtFecha(dateStr, {
    hour: '2-digit', minute: '2-digit',
  });
}
function formatShortDate(dateStr: string): string {
  return fmtFecha(dateStr, {
    weekday: 'short', day: 'numeric', month: 'short',
  });
}


type MatchRow = {
  id: string;
  home_team: string;
  away_team: string;
  match_date: string;
  stage: string;
  group_name: string | null;
  round: string | null;
  jornada: string | null;
};

// Agrupar por jornada Bolivia — el día empieza a las 03:00 AM BOT para que
// partidos de medianoche (00:00-02:59) queden con la noche anterior.
const grouped = new Map<string, MatchRow[]>();
for (const m of (matches ?? []) as MatchRow[]) {
  const dayStart = boliviaDayStart(new Date(m.match_date).getTime());
  const key = fmtFecha(dayStart, {
    weekday: 'long', day: 'numeric', month: 'long',
  });
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(m);
}

const now = nowMs;

// Días jornada (clave 03:00 BOT) que ya tuvieron al menos un partido iniciado
const daysWithStartedMatch = new Set(
  (startedMatchData ?? []).map(m => boliviaDayKey(new Date(m.match_date).getTime()))
);
// Hay algún partido en curso ahora mismo (started + unfinished, dentro de su
// ventana realista de duración: un sync atrasado no lo deja "en curso" eterno).
const hasMatchInProgress = (startedMatchData ?? []).some(m =>
  !m.is_finished && countsUnresolved(new Date(m.match_date).getTime(), now));

// Estado de bloqueo de la jornada (lógica única en lib/jornada.ts).
function lockStateFor(jornadaMatches: MatchRow[]) {
  const firstMatchMs = Math.min(...jornadaMatches.map(m => new Date(m.match_date).getTime()));
  return jornadaLockState({
    firstMatchMs,
    nowMs: now,
    sameDayStarted: daysWithStartedMatch.has(boliviaDayKey(firstMatchMs)),
    hasMatchInProgress,
    hasEarlierUnfinished: (matches ?? []).some(m => {
      const k = new Date(m.match_date).getTime();
      return k < firstMatchMs && countsUnresolved(k, now);
    }),
  });
}

// Jornadas expandidas por defecto en el acordeón:
//  (a) la VIGENTE: la que está en juego ahora (ya empezó → closed/ongoingLock);
//  (b) la SIGUIENTE: la primera accionable (abierta y con partidos por pronosticar);
//      si no hay, la próxima no cerrada.
// Las demás quedan colapsadas.
const jornadaList = [...grouped.entries()];
const openKeys = new Set<string>();
const vigente = jornadaList.find(([, ms]) => ['closed', 'ongoingLock'].includes(lockStateFor(ms)));
if (vigente) openKeys.add(vigente[0]);
const siguiente =
  jornadaList.find(([, ms]) => !isSanctioned(ms) && lockStateFor(ms) === 'open' && !ms.every(m => predMap.has(m.id)))?.[0]
  ?? jornadaList.find(([, ms]) => ['open', 'prevPending', 'ongoingLock'].includes(lockStateFor(ms)))?.[0];
if (siguiente) openKeys.add(siguiente);
if (openKeys.size === 0 && jornadaList[0]) openKeys.add(jornadaList[0][0]);

// Barra fija de cuenta regresiva (C/D): la jornada ACCIONABLE más próxima
// (abierta, sin sanción, con algo por pronosticar). Su cierre alimenta la barra
// sticky; el contador en vivo y el estado "al filo" se manejan en el cliente.
const stickyEntry = jornadaList
  .filter(([, ms]) => !isSanctioned(ms) && lockStateFor(ms) === 'open' && !ms.every(m => predMap.has(m.id)))
  .map(([key, ms]) => ({ key, firstMs: Math.min(...ms.map(m => new Date(m.match_date).getTime())) }))
  .sort((a, b) => a.firstMs - b.firstMs)[0];
const stickyCutoff = stickyEntry ? stickyEntry.firstMs - 2 * 3600 * 1000 : null;
const stickyLabel = stickyEntry?.key ?? null;
const stickyKey = stickyEntry ? String(boliviaDayKey(stickyEntry.firstMs)) : null;

// Jornada CERRADA con partidos SIN pronosticar (el jugador llegó tarde): dispara
// el popup "JORNADA CERRADA" una sola vez al entrar (lo maneja initCierreModal en
// el cliente, con registro en el log al pulsar Entendido). La clave del día evita
// que se repita por jornada (localStorage).
let lateCierreKey: string | null = null;
let lateCierreLabel: string | null = null;
for (const [jkey, jms] of jornadaList) {
  if (!isSanctioned(jms) && lockStateFor(jms) === 'closed' && jms.some((m) => !predMap.has(m.id))) {
    lateCierreKey = String(boliviaDayKey(Math.min(...jms.map((m) => new Date(m.match_date).getTime()))));
    lateCierreLabel = jkey;
    break;
  }
}

function buildShareData(dayMatches: MatchRow[], username: string) {
  const firstMatch = dayMatches[0];
  const cutoff = new Date(new Date(firstMatch.match_date).getTime() - 2 * 3600 * 1000);
  const cutoffStr = fmtFecha(cutoff, { hour: '2-digit', minute: '2-digit' });
  const items = dayMatches
    .filter(m => predMap.has(m.id))
    .map(m => {
      const pred = predMap.get(m.id)!;
      return {
        home: spanishName(m.home_team), away: spanishName(m.away_team),
        homeISO: isoForTeam(m.home_team),
        awayISO: isoForTeam(m.away_team),
        uh: pred.user_home, ua: pred.user_away,
        uhp: pred.user_home_pen ?? null, uap: pred.user_away_pen ?? null,
        pen: pred.user_winner_penalties ?? null,
      };
    });
  return JSON.stringify({ username, cutoff: cutoffStr, items });
}

const errorParam = Astro.url.searchParams.get('error');
const infoParam  = Astro.url.searchParams.get('info');
const okParam    = Astro.url.searchParams.get('ok');

// ── Verificación ACTIVA contra la BD ──────────────────────────────────────────
// submit-jornada devuelve los match_id que insertó. Aquí se confirma que esos id
// REALMENTE están en `predictions` (predMap viene de leer la BD recién). Si la
// cuenta no cuadra, algo no se guardó → se avisa en rojo (esto es lo que faltó
// en el caso Niels). El '1' es compatibilidad con envíos viejos.
const okIds = (okParam && okParam !== '1') ? okParam.split(',').filter(Boolean) : [];
const okVerified = okIds.filter((id) => predMap.has(id));
const okAllSaved = okIds.length > 0 && okVerified.length === okIds.length;

// Hora de registro (created_at real) del envío recién verificado: deja constancia
// de "a qué hora quedó guardado" para zanjar disputas de "yo mandé en hora".
const okSavedAtIso = okVerified
  .map((id) => predMap.get(id)?.created_at)
  .filter(Boolean)
  .sort()
  .at(-1) as string | undefined;
const okSavedAt = okSavedAtIso
  ? fmtFecha(okSavedAtIso, { weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit', second: '2-digit' })
  : null;
// Hora corta (solo HH:MM:SS) para mostrar junto a cada pick guardado.
function savedTime(iso: string | null | undefined): string | null {
  return iso ? fmtFecha(iso, { hour: '2-digit', minute: '2-digit', second: '2-digit' }) : null;
}

// ── Popup de resultado a pantalla completa ─────────────────────────────────────
// El feedback del envío (guardado / no guardado / fallo de BD) se muestra como un
// modal que ocupa toda la pantalla: imposible de ignorar. db_open trae un CÓDIGO
// DE VALIDACIÓN grande, espejado en el panel del Réferi, para cruzar la captura.
const codeParam = Astro.url.searchParams.get('code');
type ModalState = 'ok' | 'partial' | 'db_open' | 'error' | null;
const modalState: ModalState =
  okIds.length > 0 && okAllSaved ? 'ok'
  : okIds.length > 0 ? 'partial'
  : errorParam === 'db_open' ? 'db_open'
  : (errorParam && errorParam !== 'incompleto') ? 'error'
  : null;
const errorText =
  errorParam === 'cerrado' ? '🔒 La jornada ya está cerrada.'
  : errorParam === 'en_curso' ? '⏳ El partido ya empezó. Las apuestas para esta jornada están cerradas.'
  : errorParam ? decodeURIComponent(errorParam) : '';

// Breadcrumb: deja constancia de que el jugador VIO la confirmación de guardado.
// Los rechazos ya se loguean en submit-jornada; faltaba el lado del éxito para
// diagnosticar "no me salió el popup" con datos en vez de adivinar. El JS limpia
// el `?ok=` tras pintar, así que una recarga no vuelve a registrar. Best-effort.
if (modalState === 'ok') {
  try {
    await logEvent({
      category: 'pronostico',
      event: 'guardado:confirmado',
      actor: navProfile?.username ?? null,
      summary: `${navProfile?.username ?? '—'} — vio confirmación de guardado (${okVerified.length}/${okIds.length})`,
      detail: okIds.join(',') || null,
    });
  } catch { /* nunca rompe el render */ }
}

// Contador global de inputs — evita colisiones de nombre entre jornadas distintas
let globalFormIdx = 0;
---

<Layout title="Pronósticos" navProfile={navProfile} isAuthed={true}>
  <div class="space-y-6" data-pred-root>

    {/* ── Barra fija de cuenta regresiva (C) + aviso al filo (D) ──
         Al cerrar EN VIVO, initCountdown oculta ésta y muestra <CerradaBar> (la
         misma barra del caso 3) → formato idéntico, sin fondo gris. */}
    {stickyCutoff && (
      <Fragment>
        <div id="sticky-cd" data-cutoff={stickyCutoff} data-sticky-key={stickyKey ?? undefined} class="sticky top-[58px] z-40 py-2.5 px-4 bg-brand-950/95 backdrop-blur border border-brand-700/60 rounded-2xl flex items-center justify-center gap-3 transition-colors shadow-lg">
          <span class="sticky-cd-ico text-2xl">⏰</span>
          <div class="text-center leading-tight">
            <p class="sticky-cd-time font-display text-2xl tracking-wide" style="color:#4ade80">—</p>
            <p class="sticky-cd-label text-[11px] text-slate-300 capitalize" data-label={stickyLabel}>{stickyLabel}</p>
          </div>
        </div>
        <CerradaBar label={stickyLabel} hidden />
      </Fragment>
    )}

    {/* ── Barra fija "Cerrada" (caso 3: entró tarde, sin jornada abierta) ── */}
    {!stickyCutoff && lateCierreLabel && <CerradaBar label={lateCierreLabel} />}

    <div class="flex items-center justify-between gap-2">
      <h1 class="font-display text-4xl text-white tracking-wide">MIS PRONÓSTICOS</h1>
      <a href="/reglas" class="text-xs text-slate-500 active:text-gold transition py-2 px-1">Reglamento →</a>
    </div>

    {import.meta.env.PUBLIC_BETA !== "true" && !(navProfile?.pago_70 && navProfile?.pago_50) && (
      <div class="bg-brand-900 border border-amber-500/40 rounded-2xl p-8 text-center space-y-3">
        <div class="text-4xl">🔒</div>
        <h2 class="text-white font-bold text-lg">Pronósticos bloqueados</h2>
        <p class="text-slate-400 text-sm max-w-sm mx-auto">
          Para participar debés tener los dos pagos confirmados: <strong class="text-amber-400">70 Bs + 50 Bs</strong>.
          Una vez confirmado por el Réferi, se habilitarán tus pronósticos.
        </p>
        <p class="text-xs text-slate-600 mt-2">¿Ya pagaste? Contactá al Réferi.</p>
      </div>
    )}

    {/* ── POPUP DE RESULTADO A PANTALLA COMPLETA ──────────────────────────
         Guardado / no-guardado / fallo de BD. Imposible de ignorar. El
         estado db_open trae el código de validación grande para capturar. */}
    {modalState && (
      <div id="result-modal" class="backdropIn fixed inset-0 z-[120] flex items-center justify-center p-4 bg-brand-950/90 backdrop-blur-lg">
        <div class={`modalIn relative w-full max-w-md max-h-[92vh] overflow-y-auto rounded-[28px] p-7 text-center space-y-4 ring-1 bg-gradient-to-b from-brand-900 to-brand-950 ${
          modalState === 'ok' ? 'ring-gol/30 shadow-[0_24px_70px_-20px_rgba(34,197,94,0.45)]' :
          modalState === 'db_open' ? 'ring-amarilla/30 shadow-[0_24px_70px_-20px_rgba(245,200,66,0.4)]' :
          'ring-fifared/30 shadow-[0_24px_70px_-20px_rgba(220,38,38,0.45)]'
        }`}>

          {modalState === 'ok' && (
            <Fragment>
              <div class="iconPop mx-auto w-20 h-20 rounded-full grid place-items-center text-5xl bg-gol/15 ring-1 ring-gol/40 shadow-[0_0_44px_-6px_rgba(34,197,94,0.65)]">✅</div>
              <h2 class="font-display text-3xl tracking-wide text-gol">¡PRONÓSTICOS GUARDADOS!</h2>
              <p class="text-green-200/90 text-base">{okVerified.length} de {okIds.length} verificado{okIds.length !== 1 ? 's' : ''} en la base ✓</p>
              {okSavedAt && <p class="text-green-300/70 text-sm">🕒 Registrado el {okSavedAt}</p>}
              <button type="button" data-close-modal class="w-full bg-gradient-to-b from-gol to-green-600 text-white font-bold py-3.5 rounded-2xl shadow-lg shadow-gol/25 hover:brightness-110 active:brightness-95 transition text-base min-h-[52px]">Entendido</button>
            </Fragment>
          )}

          {modalState === 'partial' && (
            <Fragment>
              <div class="iconPop mx-auto w-20 h-20 rounded-full grid place-items-center text-5xl bg-fifared/15 ring-1 ring-fifared/40 shadow-[0_0_44px_-6px_rgba(220,38,38,0.6)]">⚠️</div>
              <h2 class="font-display text-2xl tracking-wide text-fifared">NO SE GUARDÓ TODO</h2>
              <p class="text-red-200 text-base">Solo <strong>{okVerified.length} de {okIds.length}</strong> quedaron en la base. Cierra y reenvía los que falten — tus marcadores siguen cargados.</p>
              <button type="button" data-retry class="w-full bg-gradient-to-b from-gold to-amber-500 text-brand-950 font-bold py-3.5 rounded-2xl shadow-lg shadow-gold/25 hover:brightness-110 active:brightness-95 transition text-base min-h-[52px]">Revisar y reenviar</button>
            </Fragment>
          )}

          {modalState === 'error' && (
            <Fragment>
              <div class="iconPop mx-auto w-20 h-20 rounded-full grid place-items-center text-5xl bg-fifared/15 ring-1 ring-fifared/40 shadow-[0_0_44px_-6px_rgba(220,38,38,0.6)]">⚠️</div>
              <h2 class="font-display text-2xl tracking-wide text-fifared">NO SE GUARDÓ</h2>
              <p class="text-red-200 text-base">{errorText}</p>
              <p class="text-red-300/60 text-xs">Verifica abajo: si no ves "✓ Guardado", no quedó registrado.</p>
              <button type="button" data-close-modal class="w-full bg-gradient-to-b from-fifared to-red-700 text-white font-bold py-3.5 rounded-2xl shadow-lg shadow-fifared/25 hover:brightness-110 active:brightness-95 transition text-base min-h-[52px]">Entendido</button>
            </Fragment>
          )}

          {modalState === 'db_open' && (
            <Fragment>
              <div class="iconPop mx-auto w-20 h-20 rounded-full grid place-items-center text-5xl bg-amarilla/15 ring-1 ring-amarilla/40 shadow-[0_0_44px_-6px_rgba(245,200,66,0.6)]">🛟</div>
              <h2 class="font-display text-2xl tracking-wide text-amarilla leading-tight">LA BASE FALLÓ AL GUARDAR</h2>
              <p class="text-amber-100 text-base">Tranquilo: tu pronóstico se enviará <strong>automáticamente</strong> al Réferi para que lo valide. <strong>No perdiste nada.</strong></p>
              {codeParam && (
                <div class="bg-brand-950/60 border border-amarilla/40 rounded-2xl py-4 px-3 space-y-1">
                  <p class="text-[11px] uppercase tracking-[0.25em] text-amber-200/70">Código de validación</p>
                  <p class="font-display text-5xl tracking-[0.15em] text-white">{codeParam}</p>
                </div>
              )}
              <p class="text-amber-100/90 text-sm font-semibold">📸 Toma una captura de esta pantalla y mándala al grupo.</p>
              <div class="flex gap-2 pt-1">
                <button type="button" data-retry class="flex-1 bg-gradient-to-b from-gold to-amber-500 text-brand-950 font-bold py-3.5 rounded-2xl shadow-lg shadow-gold/25 hover:brightness-110 active:brightness-95 transition min-h-[52px]">Reintentar</button>
                <button type="button" data-close-modal class="flex-1 bg-brand-800 border border-brand-700 text-slate-300 font-semibold py-3.5 rounded-2xl hover:bg-brand-700 active:brightness-95 transition min-h-[52px]">Cerrar</button>
              </div>
            </Fragment>
          )}

        </div>
      </div>
    )}

    {/* ── POPUP DE CIERRE EN VIVO ──────────────────────────────────────────
         Si la jornada cierra mientras el jugador está en la página con el
         formulario abierto, este modal lo bloquea: deja claro que ya no hay
         tiempo (lo activa initCountdown al llegar el contador a 0). */}
    <div id="cierre-modal" data-late-key={lateCierreKey ?? undefined} class="hidden fixed inset-0 z-[130] flex items-center justify-center p-4 bg-brand-950/90 backdrop-blur-lg">
      <div class="modalIn relative w-full max-w-md rounded-[28px] p-7 text-center space-y-4 ring-1 ring-fifared/30 bg-gradient-to-b from-brand-900 to-brand-950 shadow-[0_24px_70px_-20px_rgba(220,38,38,0.45)]">
        <div class="iconPop mx-auto w-20 h-20 rounded-full grid place-items-center text-5xl bg-fifared/15 ring-1 ring-fifared/40 shadow-[0_0_44px_-6px_rgba(220,38,38,0.6)]">🔒</div>
        <h2 class="font-display text-3xl tracking-wide text-fifared">JORNADA CERRADA</h2>
        <p class="text-red-100 text-base">Se acabó el tiempo para esta jornada. Ya <strong>no se aceptan pronósticos</strong>.</p>
        <p class="text-red-200/70 text-sm">Si tenías marcadores sin enviar, <strong>no quedaron registrados</strong>.</p>
        <button type="button" id="cierre-ok" class="w-full bg-gradient-to-b from-fifared to-red-700 text-white font-bold py-3.5 rounded-2xl shadow-lg shadow-fifared/25 hover:brightness-110 active:brightness-95 transition text-base min-h-[52px]">Entendido</button>
      </div>
    </div>

    {errorParam === 'incompleto' && (
      <div class="bg-fifared/15 border border-fifared/40 rounded-xl px-4 py-3 text-sm text-red-300 text-center">
        ⚠️ Completa el marcador de todos los partidos antes de enviar.
      </div>
    )}
    {infoParam === 'ya_pronosticado' && (
      <div class="bg-brand-700/40 border border-brand-600 rounded-xl px-4 py-3 text-sm text-slate-300 text-center">
        Ya registraste pronósticos para esa jornada.
      </div>
    )}

    {okParam === '1' && (
      <div class="bg-gol/10 border border-gol/30 rounded-xl px-4 py-3 text-sm text-green-300 text-center">
        ✅ Pronósticos enviados correctamente.
      </div>
    )}

    {(import.meta.env.PUBLIC_BETA === 'true' || (navProfile?.pago_70 && navProfile?.pago_50)) && grouped.size === 0 && (
      <div class="text-center py-20 text-slate-600">
        <div class="text-5xl mb-4">📅</div>
        <p class="text-base">No hay partidos disponibles por el momento.</p>
      </div>
    )}

    {(import.meta.env.PUBLIC_BETA === 'true' || (navProfile?.pago_70 && navProfile?.pago_50)) && jornadaList.map(([jornadaKey, jornadaMatches]) => {
      const sanctioned = isSanctioned(jornadaMatches);
      const lockState = lockStateFor(jornadaMatches);
      const closed = lockState === 'closed';
      const prevPending = lockState === 'prevPending';
      const ongoingLock = lockState === 'ongoingLock';
      const predCount = jornadaMatches.filter(m => predMap.has(m.id)).length;
      const allDone = predCount === jornadaMatches.length;
      const hasSome = predCount > 0;
      const firstTime = Math.min(...jornadaMatches.map(m => new Date(m.match_date).getTime()));
      const cutoffStr = fmtFecha(firstTime - 2 * 3600 * 1000, {
        weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit',
      });
      const shareData = buildShareData(jornadaMatches, navProfile?.username ?? 'yo');
      // Progreso de pronóstico (va como texto bajo el título, no como botón).
      const showProgress = !sanctioned && (allDone || hasSome || lockState === 'open');
      const progressLabel = allDone ? '✅ Completa' : `${predCount}/${jornadaMatches.length}`;
      const progressColor = allDone ? 'text-gol' : hasSome ? 'text-amarilla' : 'text-slate-400';

      return (
        <details class="group" open={openKeys.has(jornadaKey)} data-jornada>

          {/* ── Encabezado de jornada (resumen tap-able del acordeón) ── */}
          <summary class={`flex items-center justify-between gap-2 px-4 py-3 rounded-xl border cursor-pointer list-none select-none [&::-webkit-details-marker]:hidden ${
            sanctioned   ? 'bg-fifared/12 border-fifared/40' :
            prevPending  ? 'bg-brand-900 border-brand-700/40' :
            ongoingLock  ? 'bg-amber-900/10 border-amber-500/30' :
            closed       ? 'bg-fifared/8 border-fifared/30' :
            allDone      ? 'bg-gol/8 border-gol/30' :
                           'bg-brand-800/60 border-brand-700/60'
          }`}>
            <div class="flex items-center gap-2.5 min-w-0 flex-1">
              <svg class="w-4 h-4 flex-shrink-0 text-slate-500 transition-transform group-open:rotate-90" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M7 5l6 5-6 5V5z"/></svg>
              <div class="min-w-0">
                <h2 class={`font-display text-xl tracking-wide capitalize leading-tight ${prevPending ? 'text-slate-400' : 'text-white'}`}>{jornadaKey}</h2>
                <p class="text-xs mt-0.5 flex items-center gap-1.5 flex-wrap leading-tight">
                  {showProgress && <span data-progress class={`font-semibold ${progressColor}`}>{progressLabel}</span>}
                  {showProgress && <span data-progress class="text-slate-700">·</span>}
                  <span class={sanctioned ? 'text-fifared' : prevPending ? 'text-slate-500' : ongoingLock ? 'text-amber-400' : closed ? 'text-fifared/90' : 'text-slate-500'}>
                    {sanctioned
                      ? (isExpulsado ? '🟥🟥 Expulsado — no puedes pronosticar' : '🟥 Anulada por tarjeta roja')
                      : prevPending
                      ? '🔒 Disponible al terminar los anteriores'
                      : ongoingLock
                      ? '⏳ Partido en curso'
                      : closed
                      ? '🔒 Cerrada'
                      : <span class="cutoff-cd font-semibold" data-cutoff={firstTime - 2 * 3600 * 1000}>⏰ Cierre: {cutoffStr}</span>
                    }
                  </span>
                </p>
              </div>
            </div>
            <div class="flex items-center flex-shrink-0">
              {hasSome && (
                <button
                  aria-label="Compartir en WhatsApp"
                  class="share-btn flex items-center justify-center flex-shrink-0 text-[#25D366] bg-[#25D366]/10 border border-[#25D366]/30 w-10 h-10 rounded-xl transition active:bg-[#25D366]/20"
                  data-share={shareData}>
                  <svg viewBox="0 0 24 24" class="w-5 h-5 flex-shrink-0" fill="currentColor" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </button>
              )}
            </div>
          </summary>

          <div class="mt-3">
          {/* ── Si la jornada está abierta y hay partidos sin pronosticar: form inline ── */}
          {!sanctioned && !closed && !prevPending && !ongoingLock && !allDone ? (
            <Fragment>
            <form method="POST" action="/api/predictions/submit-jornada" class="space-y-2" data-astro-reload>

              {jornadaMatches.map((m) => {
                const existing = predMap.get(m.id);
                const idx = existing ? -1 : globalFormIdx++;
                const isKnockout = m.stage === 'knockout';

                return (
                  <div class={`bg-brand-900 border rounded-2xl p-4 ${existing ? 'border-gol/30 bg-gol/5' : 'border-brand-700/60'}`}>

                    {/* Fecha + etiqueta */}
                    <div class="flex items-center justify-between mb-3">
                      <span class="text-slate-400 font-medium text-xs">
                        {m.stage === 'group' ? (m.group_name ? `Grupo ${m.group_name}` : m.jornada) : m.round}
                      </span>
                      <div class="text-right">
                        <p class="text-xs text-slate-500">{formatShortDate(m.match_date)}</p>
                        <p class="font-display text-base font-bold text-gold leading-tight">{formatTime(m.match_date)}</p>
                      </div>
                    </div>

                    {/* Equipos + inputs */}
                    {existing ? (
                      /* Ya pronosticado: layout horizontal clásico */
                      <Fragment>
                      <div class="flex items-center gap-2" data-saved-match={m.id}>
                        <div class="flex-1 min-w-0">
                          <TeamName team={m.home_team} side="home" class="text-white font-semibold text-base" />
                        </div>
                        <span class="text-gol font-display text-3xl flex-shrink-0 px-2">
                          {existing.user_home}–{existing.user_away}
                        </span>
                        <div class="flex-1 min-w-0">
                          <TeamName team={m.away_team} side="away" class="text-white font-semibold text-base" />
                        </div>
                      </div>
                      <p class="text-center mt-2.5">
                        <span class="text-[11px] font-semibold text-gol bg-gol/10 border border-gol/30 rounded-full px-2.5 py-1">
                          ✓ Guardado {existing.user_home}–{existing.user_away}{savedTime(existing.created_at) && <span class="text-gol/70 font-normal"> · {savedTime(existing.created_at)}</span>}
                        </span>
                      </p>
                      </Fragment>
                    ) : (
                      /* Sin pronóstico: nombres arriba, steppers abajo */
                      <div class="space-y-3">
                        <input type="hidden" name={`matchId_${idx}`} value={m.id} />
                        <div class="flex items-center justify-between gap-2">
                          <div class="flex-1 min-w-0">
                            <TeamName team={m.home_team} side="home" class="text-white font-semibold text-base" />
                          </div>
                          <span class="text-slate-600 text-sm flex-shrink-0">vs</span>
                          <div class="flex-1 min-w-0">
                            <TeamName team={m.away_team} side="away" class="text-white font-semibold text-base" />
                          </div>
                        </div>
                        <div class="flex items-center justify-center gap-2">
                          {/* Stepper local */}
                          <div class="flex items-center gap-1">
                            <button type="button"
                              class="stepper-btn w-10 h-10 rounded-xl bg-brand-700 active:bg-brand-600 text-white text-xl font-bold flex items-center justify-center transition touch-manipulation select-none"
                              data-action="dec" data-target={`home_${idx}`}>−</button>
                            <input
                              type="number" inputmode="numeric" pattern="[0-9]*"
                              name={`home_${idx}`}
                              min="0" max="20" required value="0"
                              data-team={spanishName(m.home_team)}
                              class="w-14 bg-brand-800 border-2 border-brand-700 rounded-xl py-2 text-white text-2xl font-display text-center focus:outline-none focus:border-gold transition"
                            />
                            <button type="button"
                              class="stepper-btn w-10 h-10 rounded-xl bg-brand-700 active:bg-brand-600 text-white text-xl font-bold flex items-center justify-center transition touch-manipulation select-none"
                              data-action="inc" data-target={`home_${idx}`}>+</button>
                          </div>
                          <span class="text-slate-500 font-bold text-xl px-1">–</span>
                          {/* Stepper visitante */}
                          <div class="flex items-center gap-1">
                            <button type="button"
                              class="stepper-btn w-10 h-10 rounded-xl bg-brand-700 active:bg-brand-600 text-white text-xl font-bold flex items-center justify-center transition touch-manipulation select-none"
                              data-action="dec" data-target={`away_${idx}`}>−</button>
                            <input
                              type="number" inputmode="numeric" pattern="[0-9]*"
                              name={`away_${idx}`}
