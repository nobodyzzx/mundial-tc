---
import Layout from '@/layouts/Layout.astro';
import { supabase, supabaseAdmin } from '@/lib/supabase';
import { spanishName } from '@/lib/isoFlags';
import { fmtFecha } from '@/lib/fechas';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
if (!accessToken || !refreshToken) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: { user } } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
if (!user) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: navProfile } = await supabase.from('profiles').select('username, puntos_totales, es_referi').eq('id', user.id).single();
if (!navProfile?.es_referi) return Astro.redirect('/dashboard');

// Últimos intentos rechazados (best-effort log de submit-jornada).
const { data: rawAttempts } = await supabaseAdmin
  .from('submit_attempts')
  .select('id, username, reason, detail, created_at')
  .order('created_at', { ascending: false })
  .limit(300);
const attempts = rawAttempts ?? [];

// Resolver los UUID de partido que aparecen en `detail` a nombres de equipos.
const idRe = /[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/gi;
const matchIds = [...new Set(attempts.flatMap(a => (a.detail ?? '').match(idRe) ?? []))];
const matchMap = new Map<string, { home_team: string; away_team: string }>();
if (matchIds.length) {
  const { data: ms } = await supabaseAdmin.from('matches').select('id, home_team, away_team').in('id', matchIds);
  for (const m of ms ?? []) matchMap.set(m.id, m);
}

// Motivos legibles + color.
const REASONS: Record<string, { label: string; cls: string }> = {
  'jornada-cerrada':        { label: 'Jornada cerrada',     cls: 'text-fifared bg-fifared/10 border-fifared/30' },
  'partido-en-juego':       { label: 'Partido en juego',    cls: 'text-fifared bg-fifared/10 border-fifared/30' },
  'partido-terminado':      { label: 'Partido terminado',   cls: 'text-fifared bg-fifared/10 border-fifared/30' },
  'roja-jornada-anulada':   { label: 'Roja (anulada)',      cls: 'text-fifared bg-fifared/10 border-fifared/30' },
  'expulsado':              { label: 'Expulsado',           cls: 'text-fifared bg-fifared/10 border-fifared/30' },
  'no-pagado':              { label: 'Pago incompleto',     cls: 'text-amber-400 bg-amber-400/10 border-amber-400/30' },
  'form-invalido':          { label: 'Datos inválidos',     cls: 'text-amber-400 bg-amber-400/10 border-amber-400/30' },
  'sin-entradas':           { label: 'Sin entradas',        cls: 'text-amber-400 bg-amber-400/10 border-amber-400/30' },
  'knockout-sin-penales':   { label: 'Faltan penales',      cls: 'text-amber-400 bg-amber-400/10 border-amber-400/30' },
  'partidos-no-encontrados':{ label: 'Partidos no hallados', cls: 'text-amber-400 bg-amber-400/10 border-amber-400/30' },
  'ya-pronosticado':        { label: 'Ya había pronosticado', cls: 'text-slate-400 bg-slate-400/10 border-slate-500/30' },
  'error-db':               { label: 'Error de BD',         cls: 'text-purple-300 bg-purple-400/10 border-purple-400/30' },
};
const reasonInfo = (r: string) => REASONS[r] ?? { label: r, cls: 'text-slate-400 bg-slate-400/10 border-slate-500/30' };

// "uuid:2-1 (pen 4-3) | uuid:1-2" → ["Canadá-Bosnia 2-1 (pen 4-3)", "EEUU-Paraguay 1-2"]
function readableDetail(detail: string | null): string[] {
  if (!detail) return [];
  const main = detail.split(' || db:')[0];
  return main.split(' | ').map(seg => {
    const m = seg.match(/^([0-9a-f-]{36}):(.+)$/i);
    if (!m) return seg;
    const match = matchMap.get(m[1]);
    const teams = match ? `${spanishName(match.home_team)}–${spanishName(match.away_team)}` : 'partido?';
    return `${teams} ${m[2]}`;
  });
}

// Resumen por motivo.
const byReason = new Map<string, number>();
for (const a of attempts) byReason.set(a.reason, (byReason.get(a.reason) ?? 0) + 1);
const summary = [...byReason.entries()].sort((a, b) => b[1] - a[1]);
---

<Layout title="Intentos rechazados" navProfile={navProfile} isAuthed={true}>
  <div class="space-y-6">

    <div class="flex items-center justify-between gap-2 flex-wrap">
      <div>
        <h1 class="font-display text-4xl text-white tracking-wide">INTENTOS RECHAZADOS</h1>
        <p class="text-slate-500 text-sm mt-1">Envíos de pronóstico que el sistema no aceptó · {attempts.length} registro{attempts.length !== 1 ? 's' : ''}</p>
      </div>
      <a href="/admin" class="text-xs text-slate-500 hover:text-white transition px-3 py-1.5 border border-brand-700 rounded-lg">
        ← Panel VAR
      </a>
    </div>

    {summary.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {summary.map(([r, n]) => (
          <span class={`text-xs px-2.5 py-1 rounded-full border ${reasonInfo(r).cls}`}>
            {reasonInfo(r).label} · {n}
          </span>
        ))}
      </div>
    )}

    {attempts.length === 0 && (
      <div class="text-center py-20 text-slate-600">
        <div class="text-5xl mb-4">✅</div>
        <p>Sin intentos rechazados registrados.</p>
        <p class="text-xs mt-2 text-slate-700">Aquí aparecerán los envíos que no se guarden (jornada cerrada, partido en juego, etc.) con la hora y lo que intentó cada uno.</p>
      </div>
    )}

    <div class="space-y-2">
      {attempts.map((a: any) => {
        const info = reasonInfo(a.reason);
        const picks = readableDetail(a.detail);
        const recoverable = a.reason === 'jornada-cerrada' || a.reason === 'partido-en-juego';
        return (
          <div class="bg-brand-900 border border-brand-700/60 rounded-xl px-4 py-3">
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <div class="flex items-center gap-2 min-w-0">
                <span class="font-semibold text-white text-sm truncate">{a.username ?? '—'}</span>
                <span class={`text-[11px] px-2 py-0.5 rounded-full border flex-shrink-0 ${info.cls}`}>{info.label}</span>
              </div>
              <span class="text-xs text-slate-500 font-mono flex-shrink-0">
                {fmtFecha(a.created_at, { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' })}
              </span>
            </div>
            {picks.length > 0 && (
              <div class="mt-2 flex flex-wrap gap-1.5">
                {picks.map((p: string) => (
                  <span class="text-xs font-mono text-slate-300 bg-brand-800/60 border border-brand-700/50 px-2 py-0.5 rounded">{p}</span>
                ))}
              </div>
            )}
            {recoverable && picks.length > 0 && (
              <a href="/admin/ingresar" class="inline-block mt-2 text-[11px] text-gold/80 hover:text-gold transition">
                → Cargar manualmente en Ingresar
              </a>
            )}
          </div>
        );
      })}
    </div>

    <p class="text-xs text-slate-600 pt-2">
      Hora en zona Bolivia. El registro guarda lo que el jugador intentó enviar; el marcador mostrado es el del intento, no necesariamente el final.
    </p>

  </div>
</Layout>
