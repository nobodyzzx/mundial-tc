---
import Layout from '@/layouts/Layout.astro';
import { supabase, supabaseAdmin } from '@/lib/supabase';
import { fmtFecha } from '@/lib/fechas';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
if (!accessToken || !refreshToken) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: { user } } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
if (!user) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: navProfile } = await supabase.from('profiles').select('username, puntos_totales, es_referi').eq('id', user.id).single();
if (!navProfile?.es_referi) return Astro.redirect('/dashboard');

// Últimos accesos (entradas/salidas).
const { data: rawLog } = await supabaseAdmin
  .from('access_log')
  .select('username, event, method, created_at')
  .order('created_at', { ascending: false })
  .limit(300);
const log = rawLog ?? [];

// Última actividad por jugador (para ver "¿desde cuándo no entra?").
const lastByUser = new Map<string, { event: string; at: string }>();
for (const r of log) {
  const k = r.username ?? '—';
  if (!lastByUser.has(k)) lastByUser.set(k, { event: r.event, at: r.created_at });
}
const lastSeen = [...lastByUser.entries()].sort((a, b) => Date.parse(b[1].at) - Date.parse(a[1].at));

const fmt = (iso: string) => fmtFecha(iso, { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
---

<Layout title="Accesos" navProfile={navProfile} isAuthed={true}>
  <div class="space-y-6">

    <div class="flex items-center justify-between gap-2 flex-wrap">
      <div>
        <h1 class="font-display text-4xl text-white tracking-wide">ACCESOS</h1>
        <p class="text-slate-500 text-sm mt-1">Entradas y salidas del sistema · {log.length} registro{log.length !== 1 ? 's' : ''}</p>
      </div>
      <a href="/admin" class="text-xs text-slate-500 hover:text-white transition px-3 py-1.5 border border-brand-700 rounded-lg">
        ← Panel VAR
      </a>
    </div>

    {log.length === 0 && (
      <div class="text-center py-20 text-slate-600">
        <div class="text-5xl mb-4">🚪</div>
        <p>Sin accesos registrados todavía.</p>
        <p class="text-xs mt-2 text-slate-700">Aquí aparecerán las entradas (login) y salidas (logout) con su hora.</p>
      </div>
    )}

    {lastSeen.length > 0 && (
      <section class="space-y-2">
        <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest border-b border-brand-800 pb-2">Última actividad por jugador</h2>
        <div class="flex flex-wrap gap-2">
          {lastSeen.map(([name, info]) => (
            <span class="text-xs bg-brand-900 border border-brand-700/60 rounded-full px-3 py-1 text-slate-300">
              {name} · <span class="text-slate-500">{info.event === 'login' ? '🟢 entró' : '⚪ salió'} {fmt(info.at)}</span>
            </span>
          ))}
        </div>
      </section>
    )}

    {log.length > 0 && (
      <section class="space-y-2">
        <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest border-b border-brand-800 pb-2">Historial</h2>
        <div class="space-y-1.5">
          {log.map((r: any) => (
            <div class="bg-brand-900 border border-brand-700/60 rounded-lg px-4 py-2.5 flex items-center justify-between gap-3">
              <div class="flex items-center gap-2 min-w-0">
                <span class={`text-[11px] px-2 py-0.5 rounded-full border flex-shrink-0 ${r.event === 'login' ? 'text-gol bg-gol/10 border-gol/30' : 'text-slate-400 bg-slate-400/10 border-slate-500/30'}`}>
                  {r.event === 'login' ? '🟢 Entrada' : '⚪ Salida'}
                </span>
                <span class="font-semibold text-white text-sm truncate">{r.username ?? '—'}</span>
                {r.method && <span class="text-[11px] text-slate-600">· {r.method}</span>}
              </div>
              <span class="text-xs text-slate-500 font-mono flex-shrink-0">{fmt(r.created_at)}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    <p class="text-xs text-slate-600 pt-2">Hora en zona Bolivia.</p>

  </div>
</Layout>
