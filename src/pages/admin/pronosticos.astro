---
import Layout from '@/layouts/Layout.astro';
import { supabase, supabaseAdmin } from '@/lib/supabase';
import { betaNowMs } from '@/lib/betaTime';
import { boliviaDayStart } from '@/lib/jornada';
import { isoForTeam, spanishName, teamFlag } from '@/lib/isoFlags';
import { fmtFecha } from '@/lib/fechas';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
if (!accessToken || !refreshToken) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: { user } } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
if (!user) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: navProfile } = await supabase.from('profiles').select('username, puntos_totales, es_referi').eq('id', user.id).single();
if (!navProfile?.es_referi) return Astro.redirect('/dashboard');

const [
  { data: rawMatches },
  { data: rawPlayers },
  { data: rawSanctions },
] = await Promise.all([
  supabaseAdmin.from('matches').select('id, home_team, away_team, home_score, away_score, home_pen, away_pen, winner_penalties, stage, group_name, round, jornada, match_date, is_finished').order('match_date', { ascending: true }),
  supabaseAdmin.from('profiles').select('id, username').eq('participa', true).eq('expulsado', false).order('puntos_totales', { ascending: false }),
  supabaseAdmin.from('sanctions').select('user_id, created_at').in('type', ['red', 'double_red']).eq('active', true),
]);

const allMatches = rawMatches ?? [];
const players    = rawPlayers ?? [];

// Roja activa por usuario y día Bolivia (frontera 03:00 BOT) → jornada anulada.
const dayTimeOf = (d: string) => boliviaDayStart(new Date(d).getTime()).getTime();
const sanctionSet = new Set((rawSanctions ?? []).map((s: any) => `${s.user_id}|${dayTimeOf(s.created_at)}`));
const isSanctioned = (userId: string, matchDate: string) => sanctionSet.has(`${userId}|${dayTimeOf(matchDate)}`);

const allMatchIds = allMatches.map((m: any) => m.id);
const rawPreds = allMatchIds.length
  ? (await supabaseAdmin.from('predictions')
      .select('user_id, match_id, user_home, user_away, user_home_pen, user_away_pen, user_winner_penalties, points_earned, ingresado_por_referi')
      .in('match_id', allMatchIds)
    ).data ?? []
  : [];

const predMap: Record<string, Record<string, any>> = {};
for (const p of rawPreds) {
  if (!predMap[p.match_id]) predMap[p.match_id] = {};
  predMap[p.match_id][p.user_id] = p;
}

// Agrupar por jornada
const jornadaOrder: string[] = [];
const jornadaMatches: Record<string, any[]> = {};
for (const m of allMatches) {
  const k = (m as any).jornada ?? 'Sin jornada';
  if (!jornadaMatches[k]) { jornadaMatches[k] = []; jornadaOrder.push(k); }
  jornadaMatches[k].push(m);
}

// Día de juego Bolivia (frontera 03:00 BOT) — para agrupar y compartir por día
const dayKeyOf   = (d: string) => boliviaDayStart(new Date(d).getTime()).toISOString();
const dayLabelOf = (d: string) => fmtFecha(boliviaDayStart(new Date(d).getTime()), { weekday: 'short', day: 'numeric', month: 'short' });

// Día Bolivia de "hoy" (para el toggle Hoy) y jornada a abrir por defecto (la
// primera sin terminar → corta el scroll inicial; el resto se abre con los chips).
const todayKey  = dayKeyOf(new Date(betaNowMs()).toISOString());
const firstOpenJi = jornadaOrder.findIndex((j) => !jornadaMatches[j].every((m: any) => m.is_finished));

// Datos para compartir via WhatsApp
const shareData = jornadaOrder.map((jornada) => ({
  jornada,
  matches: jornadaMatches[jornada].map((m: any) => ({
    id: m.id,
    dayKey: dayKeyOf(m.match_date),
    dayLabel: dayLabelOf(m.match_date),
    home: spanishName(m.home_team),
    away: spanishName(m.away_team),
    homeISO: isoForTeam(m.home_team),
    awayISO: isoForTeam(m.away_team),
    hs: m.home_score,
    as_: m.away_score,
    homePen: m.home_pen ?? null,
    awayPen: m.away_pen ?? null,
    winnerPen: m.winner_penalties ?? null,
    finished: m.is_finished,
    players: players.map((pl: any) => {
      const pred = predMap[m.id]?.[pl.id];
      return {
        name: pl.username,
        sanctioned: isSanctioned(pl.id, m.match_date),
        ref: pred?.ingresado_por_referi ?? false,
        uh: pred?.user_home   ?? null,
        ua: pred?.user_away   ?? null,
        uhp: pred?.user_home_pen ?? null,
        uap: pred?.user_away_pen ?? null,
        uwp: pred?.user_winner_penalties ?? null,
        pts: pred?.points_earned ?? null,
      };
    }),
  })),
}));

function predLabel(pred: any): string {
  if (!pred) return '—';
  const s = `${pred.user_home}–${pred.user_away}`;
  if (pred.user_home_pen !== null && pred.user_away_pen !== null)
    return `${s} (${pred.user_home_pen}–${pred.user_away_pen})`;
  return s;
}

function predClass(pred: any, m: any): string {
  if (!pred) return 'text-slate-700';
  if (!m.is_finished) return 'text-slate-300';
  if (pred.points_earned === null) return 'text-slate-500';
  if (pred.user_home === m.home_score && pred.user_away === m.away_score) return 'text-gold font-bold';
  const pr = pred.user_home > pred.user_away ? 'H' : pred.user_home < pred.user_away ? 'A' : 'E';
  const mr = m.home_score  > m.away_score   ? 'H' : m.home_score  < m.away_score   ? 'A' : 'E';
  if (pr === mr) return 'text-gol';
  return 'text-slate-500';
}

function ptsLabel(pred: any, m: any): string {
  if (!pred || !m.is_finished || pred.points_earned === null) return '';
  return `${pred.points_earned}p`;
}

const WA_ICON = `<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.525 5.847L0 24l6.335-1.502A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.794 9.794 0 01-5.001-1.371l-.359-.214-3.723.883.939-3.63-.234-.374A9.775 9.775 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/></svg>`;
---

<Layout title="Pronósticos" navProfile={navProfile} isAuthed={true}>
  <div class="space-y-6" id="pron-root">

    <div class="flex items-center justify-between gap-2 flex-wrap">
      <div>
        <h1 class="font-display text-4xl text-white tracking-wide">PRONÓSTICOS</h1>
        <p class="text-slate-500 text-sm mt-1">Vista consolidada · {players.length} participantes · {allMatches.length} partidos</p>
      </div>
      <a href="/admin" class="text-xs text-slate-500 hover:text-white transition px-3 py-1.5 border border-brand-700 rounded-lg flex-shrink-0">
        ← Panel VAR
      </a>
    </div>

    {/* ── Barra de herramientas (filtros + navegación) ── */}
    {jornadaOrder.length > 0 && (
      <div id="pron-toolbar" class="sticky top-0 z-20 -mx-1 px-1 py-2 bg-brand-950/90 backdrop-blur border-b border-brand-800 space-y-2">
        <div class="flex items-center gap-2 flex-wrap">
          {/* Filtro por jugador */}
          <select id="filter-player" class="text-xs bg-brand-900 border border-brand-700 text-slate-200 rounded-lg px-2 py-1.5 max-w-[150px]">
            <option value="">👥 Todos los jugadores</option>
            {players.map((pl: any) => <option value={pl.id}>{pl.username}</option>)}
          </select>
          {/* Toggles de estado */}
          <div class="inline-flex rounded-lg border border-brand-700 overflow-hidden text-xs">
            <button data-status-filter="all"      class="status-btn px-2.5 py-1.5 text-white bg-brand-700">Todos</button>
            <button data-status-filter="today"    class="status-btn px-2.5 py-1.5 text-slate-400 border-l border-brand-700">Hoy</button>
            <button data-status-filter="finished" class="status-btn px-2.5 py-1.5 text-slate-400 border-l border-brand-700">Terminados</button>
            <button data-status-filter="pending"  class="status-btn px-2.5 py-1.5 text-slate-400 border-l border-brand-700">Pendientes</button>
          </div>
          {/* Contraer / expandir todo */}
          <button id="toggle-all" data-mode="expand" class="text-xs text-slate-400 hover:text-white border border-brand-700 rounded-lg px-2.5 py-1.5 transition">⊕ Expandir todo</button>
        </div>
        {/* Salto a jornada */}
        <div class="flex items-center gap-1.5 overflow-x-auto pb-0.5 -mb-0.5">
          {jornadaOrder.map((jornada, ji) => (
            <a href={`#j-${ji}`} class="jump-chip text-[11px] whitespace-nowrap px-2 py-1 rounded-full border border-brand-700 text-slate-400 hover:text-white hover:border-brand-500 transition flex-shrink-0">
              {jornada.replace(/Jornada /i, 'J').toUpperCase()}
            </a>
          ))}
        </div>
      </div>
    )}

    <p id="filter-empty" class="hidden text-center py-12 text-slate-600 text-sm">Nada que mostrar con este filtro.</p>

    {jornadaOrder.length === 0 && (
      <div class="text-center py-20 text-slate-600">
        <div class="text-5xl mb-4">📋</div>
        <p>No hay partidos cargados aún.</p>
      </div>
    )}

    {jornadaOrder.map((jornada, ji) => {
      const matches = jornadaMatches[jornada];
      const allFinished = matches.every((m: any) => m.is_finished);
      const anyFinished = matches.some((m: any) => m.is_finished);
      return (
        <details id={`j-${ji}`} data-jornada open={ji === firstOpenJi} class="group bg-brand-900 border border-brand-700/60 rounded-2xl overflow-hidden scroll-mt-28">
          <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer list-none select-none">
            <div class="flex items-center gap-3">
              <span class="font-display text-lg text-white tracking-wide">{jornada.toUpperCase()}</span>
              <span class={`text-xs px-2 py-0.5 rounded-full border ${allFinished ? 'border-brand-600 text-slate-500' : anyFinished ? 'border-gold/40 text-gold' : 'border-gol/40 text-gol'}`}>
                {allFinished ? 'Terminada' : anyFinished ? 'En curso' : 'Pendiente'}
              </span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs text-slate-600">{matches.length} partido{matches.length !== 1 ? 's' : ''}</span>
              <button
                data-share-jornada
                data-ji={ji}
                class="flex items-center gap-1 bg-[#25D366]/10 border border-[#25D366]/30 text-[#25D366] hover:bg-[#25D366]/20 transition px-2 py-1 rounded-full text-xs font-medium"
                title="Copiar la jornada completa para WhatsApp"
              >
                <Fragment set:html={WA_ICON} /> Jornada
              </button>
              <svg class="w-4 h-4 text-slate-600 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </summary>

          <div class="border-t border-brand-800">
            {matches.map((m: any, mi: number) => {
              const preds    = predMap[m.id] ?? {};
              const submitted = players.filter((pl: any) => preds[pl.id]);
              const missing   = players.filter((pl: any) => !preds[pl.id]);
              const isClosed  = new Date(m.match_date).getTime() - 7200000 < betaNowMs();
              const dk      = dayKeyOf(m.match_date);
              const status  = m.is_finished ? 'finished' : isClosed ? 'closed' : 'open';
              const isToday = dk === todayKey;
              const showDay = mi === 0 || dayKeyOf(matches[mi - 1].match_date) !== dk;
              return (
                <Fragment>
                {showDay && (
                  <div data-daysep data-ji={ji} data-day={dk} class="flex items-center gap-3 px-5 py-2 bg-brand-950/40 border-b border-brand-800/60">
                    <span class="text-xs font-semibold text-slate-400 uppercase tracking-wide whitespace-nowrap capitalize">{dayLabelOf(m.match_date)}</span>
                    <div class="flex-1 h-px bg-brand-700/40"></div>
                    <button
                      data-share-day
                      data-ji={ji}
                      data-day={dk}
                      class="flex items-center gap-1 bg-[#25D366]/10 border border-[#25D366]/30 text-[#25D366] hover:bg-[#25D366]/20 transition px-2 py-1 rounded-full text-xs font-medium flex-shrink-0"
                      title="Copiar solo este día para WhatsApp"
                    >
                      <Fragment set:html={WA_ICON} /> Día
                    </button>
                  </div>
                )}
                <div data-match data-status={status} data-today={isToday ? '1' : '0'} data-ji={ji} data-day={dk} class="border-b border-brand-800/60 last:border-b-0">
                  {/* Cabecera del partido — nombres completos, sin cortar */}
                  <div class="px-5 py-3 bg-brand-800/40 space-y-1.5">
                    <div class="flex items-center gap-2 text-sm font-semibold text-white">
                      <span class="flex-shrink-0">{teamFlag(m.home_team)}</span>
                      <span>{spanishName(m.home_team)}</span>
                      <span class="text-brand-500 font-display flex-shrink-0">
                        {m.is_finished ? `${m.home_score}–${m.away_score}` : 'vs'}
                      </span>
                      <span>{spanishName(m.away_team)}</span>
                      <span class="flex-shrink-0">{teamFlag(m.away_team)}</span>
                    </div>
                    <div class="flex items-center gap-2 text-xs flex-wrap">
                      <span class="text-slate-600">
                        {fmtFecha(m.match_date, { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' })}
                      </span>
                      {m.is_finished
                        ? <span class="text-gol bg-gol/10 border border-gol/20 px-2 py-0.5 rounded-full">✓ Terminado</span>
                        : isClosed
                        ? <span class="text-gold bg-gold/10 border border-gold/20 px-2 py-0.5 rounded-full">🔒 Cerrado</span>
                        : <span class="text-slate-500 bg-brand-800 border border-brand-700 px-2 py-0.5 rounded-full">Abierto</span>
                      }
                      <span class={submitted.length === players.length ? 'text-gol' : 'text-slate-500'}>{submitted.length}/{players.length}</span>
                      <button
                        data-share-match
                        data-ji={ji}
                        data-mi={mi}
                        class="ml-auto flex items-center gap-1 bg-[#25D366]/10 border border-[#25D366]/30 text-[#25D366] hover:bg-[#25D366]/20 transition px-2 py-1 rounded-full font-medium flex-shrink-0"
                        title="Copiar este partido para WhatsApp"
                      >
                        <Fragment set:html={WA_ICON} /> WA
                      </button>
                    </div>
                  </div>

                  {/* Pronósticos — grilla alineada de 2 columnas */}
                  <div class="px-5 py-3">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1">
                      {players.map((pl: any) => {
                        const pred = preds[pl.id];
                        const sanc = isSanctioned(pl.id, m.match_date);
                        return (
                          <div data-pl={pl.id} data-has={pred ? '1' : '0'} class="pred-cell items-center gap-2 py-0.5 border-b border-brand-800/30">
                            {sanc && <span class="flex-shrink-0" title="Tarjeta roja — jornada anulada">🟥</span>}
                            <span class="text-xs text-slate-400 truncate flex-1 min-w-0">{pl.username}</span>
                            {pred?.ingresado_por_referi && <span class="text-[10px] flex-shrink-0" title="Ingresado por el réferi">⚖️</span>}
                            <span class={`text-xs font-mono tabular-nums flex-shrink-0 ${predClass(pred, m)}`}>
                              {predLabel(pred)}
                            </span>
                            <span class={`text-[10px] font-bold w-6 text-right flex-shrink-0 ${pred && pred.points_earned > 0 ? 'text-gol' : 'text-slate-600'}`}>
                              {ptsLabel(pred, m)}
                            </span>
                          </div>
                        );
                      })}
                    </div>

                    {missing.length > 0 && (
                      <p class="sinpron mt-2 text-[11px] text-fifared/70 leading-relaxed">
                        ⛔ Sin pronóstico: {missing.map((pl: any, k: number) => (
                          <Fragment>{k > 0 ? ', ' : ''}{isSanctioned(pl.id, m.match_date) ? '🟥 ' : ''}{pl.username}</Fragment>
                        ))}
                      </p>
                    )}
                  </div>
                </div>
                </Fragment>
              );
            })}
          </div>
        </details>
      );
    })}

    {jornadaOrder.length > 0 && (
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-slate-600 pb-4">
        <div class="flex items-center gap-1.5"><span class="text-gold font-bold font-mono">2–1</span><span>Exacto</span></div>
        <div class="flex items-center gap-1.5"><span class="text-gol font-mono">1–0</span><span>Resultado correcto</span></div>
        <div class="flex items-center gap-1.5"><span class="text-slate-500 font-mono">0–2</span><span>Incorrecto</span></div>
        <div class="flex items-center gap-1.5"><span class="text-slate-300 font-mono">1–1</span><span>Pendiente</span></div>
        <div class="flex items-center gap-1.5"><span class="text-slate-700 font-mono">—</span><span>Sin pronóstico</span></div>
      </div>
    )}

  </div>
</Layout>

<style is:global>
  /* La grilla muestra solo a quienes pronosticaron; los que no, van en la línea ⛔. */
  .pred-cell { display: flex; }
  .pred-cell[data-has="0"] { display: none; }
  /* Modo aislar un jugador: oculta el resto; la regla del seleccionado se inyecta por JS. */
  #pron-root[data-iso] .pred-cell { display: none !important; }
  #pron-root[data-iso] .sinpron   { display: none !important; }
  /* Oculto por filtro de estado (partido / separador de día / jornada). */
  .hidden-f { display: none !important; }
</style>

<script is:inline type="application/json" id="pronosticos-data" set:html={JSON.stringify(shareData)} />

<script>
  function showToast(msg: string) {
    const el = document.createElement('div');
    el.textContent = msg;
    el.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0d1117;border:1px solid #25d366;color:#fff;padding:12px 20px;border-radius:12px;font-size:14px;z-index:9999;pointer-events:none;white-space:nowrap;text-align:center;max-width:90vw';
    document.body.appendChild(el);
    setTimeout(() => { el.style.transition = 'opacity .3s'; el.style.opacity = '0'; setTimeout(() => el.remove(), 300); }, 3500);
  }

  async function copyText(text: string): Promise<boolean> {
    try { await navigator.clipboard.writeText(text); return true; } catch { /* fallback */ }
    try {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.setAttribute('readonly', '');
      ta.style.cssText = 'position:fixed;top:0;left:0;opacity:0';
      document.body.appendChild(ta);
      ta.focus(); ta.select();
      const ok = (document as any).execCommand('copy'); // fallback legacy (Firefox)
      ta.remove();
      return ok;
    } catch { return false; }
  }

  async function waShare(text: string) {
    // Si el mensaje incluye el distintivo del réferi, añade su leyenda al pie.
    if (text.includes('⚖️') && !text.includes('= ingresado por el réferi')) {
      text += '\n\n_⚖️ = ingresado por el réferi_';
    }
    // Mobile: compartir nativo (app WhatsApp) o wa.me directo
    if (/Android|iPhone|iPad|iPod/i.test(navigator.userAgent)) {
      if (navigator.share) {
        try { await navigator.share({ text }); return; } catch (e) {
          if ((e as Error).name === 'AbortError') return; // usuario canceló
        }
      }
      window.open('https://wa.me/?text=' + encodeURIComponent(text), '_blank');
      return;
    }
    // Desktop: SIEMPRE copiar. Nunca abrir WhatsApp web (mangla emojis y salen rombos).
    const copied = await copyText(text);
    if (!copied) { showToast('⚠️ No se pudo copiar al portapapeles'); return; }
    showToast('\uD83D\uDCCB Copiado \u2014 peg\u00e1lo en WhatsApp con Ctrl+V');
  }

  function flagFromISO(iso: string): string {
    if (!iso) return '';
    const code = iso.includes('-') ? iso.split('-')[0] : iso;
    const base = 0x1F1E6 - 65;
    return String.fromCodePoint(code.charCodeAt(0) + base, code.charCodeAt(1) + base);
  }

  type Player = { name: string; sanctioned?: boolean; ref?: boolean; uh: number|null; ua: number|null; uhp: number|null; uap: number|null; uwp: string|null; pts: number|null };
  type MatchData = { id: string; dayKey: string; dayLabel: string; home: string; away: string; homeISO: string; awayISO: string; hs: number|null; as_: number|null; homePen: number|null; awayPen: number|null; winnerPen: string|null; finished: boolean; players: Player[] };
  type JornadaData = { jornada: string; matches: MatchData[] };

  function getData(): JornadaData[] {
    return JSON.parse(document.getElementById('pronosticos-data')?.textContent ?? '[]');
  }

  function matchHeader(m: MatchData, hf: string, af: string, jornada: string): string {
    let line: string;
    if (m.finished && m.hs !== null) {
      line = `\u26BD *${m.home} ${hf} ${m.hs}\u2013${m.as_} ${af} ${m.away}*`;
      if (m.winnerPen) {
        const winner   = m.winnerPen === 'home' ? m.home : m.away;
        const penScore = m.homePen !== null ? `${m.homePen}\u2013${m.awayPen} pen` : 'pen';
        line += `\n_(${penScore} \u00B7 clasifica ${winner})_`;
      }
    } else {
      line = `\u26BD *${m.home} ${hf} vs ${af} ${m.away}*`;
    }
    line += `\n_${jornada} \u00B7 Polla 2026_`;
    return line;
  }

  function playerLine(pl: Player, m: MatchData): string {
    if (pl.sanctioned) return `\ud83d\udfe5 ${pl.name} _(jornada anulada)_`;
    if (pl.uh === null || pl.ua === null) return `\u2796 ${pl.name}`;
    const mark = pl.ref ? ' \u2696\ufe0f' : ''; // \u2696\ufe0f = ingresado por el r\u00e9feri
    let predStr = `${pl.uh}\u2013${pl.ua}`;
    // Pen solo si pronosticó empate
    if (pl.uh === pl.ua && pl.uwp) {
      const wName = pl.uwp === 'home' ? m.home : m.away;
      predStr += pl.uhp !== null
        ? ` (pen ${pl.uhp}\u2013${pl.uap})`
        : ` (pen ${wName})`;
    }
    if (m.finished && m.hs !== null) {
      const isExact = pl.uh === m.hs && pl.ua === m.as_;
      const pR = pl.uh > pl.ua ? 'H' : pl.uh < pl.ua ? 'A' : 'E';
      const rR = (m.hs ?? 0) > (m.as_ ?? 0) ? 'H' : (m.hs ?? 0) < (m.as_ ?? 0) ? 'A' : 'E';
      const icon = isExact ? '\u2B50' : pR === rR ? '\u2705' : '\u274C';
      return `${icon} ${pl.name}${mark} \u2192 ${predStr} (${pl.pts ?? 0}pts)`;
    }
    return `\uD83C\uDFAF ${pl.name}${mark} \u2192 ${predStr}`;
  }

  function shareMatch(ji: number, mi: number) {
    const data = getData();
    const j = data[ji];
    const m = j?.matches[mi];
    if (!m) return;
    const hf = flagFromISO(m.homeISO);
    const af = flagFromISO(m.awayISO);

    let text = matchHeader(m, hf, af, j.jornada) + '\n\n';
    const sorted = m.finished ? [...m.players].sort((a, b) => (b.pts ?? 0) - (a.pts ?? 0)) : m.players;
    for (const pl of sorted) text += playerLine(pl, m) + '\n';
    if (m.finished) {
      const total = sorted.reduce((s, p) => s + (p.pts ?? 0), 0);
      if (total > 0) text += `\n_Total: ${total}pts_`;
    }
    waShare(text);
  }

  function shareJornada(ji: number) {
    const data = getData();
    const j = data[ji];
    if (!j) return;

    let text = `\u26BD *POLLA 2026 \u00B7 ${j.jornada.toUpperCase()}*\n\n`;
    const playerTotals: Record<string, number> = {};

    for (const m of j.matches) {
      const hf = flagFromISO(m.homeISO);
      const af = flagFromISO(m.awayISO);
      if (m.finished && m.hs !== null) {
        let header = `*${m.home} ${hf} ${m.hs}\u2013${m.as_} ${af} ${m.away}*`;
        if (m.winnerPen) {
          const winner   = m.winnerPen === 'home' ? m.home : m.away;
          const penScore = m.homePen !== null ? `${m.homePen}\u2013${m.awayPen} pen` : 'pen';
          header += `\n_(${penScore} \u00B7 clasifica ${winner})_`;
        }
        text += header + '\n';
        for (const pl of m.players) {
          text += playerLine(pl, m) + '\n';
          if (pl.uh !== null) playerTotals[pl.name] = (playerTotals[pl.name] ?? 0) + (pl.pts ?? 0);
        }
      } else {
        text += `*${m.home} ${hf} vs ${af} ${m.away}*\n`;
        for (const pl of m.players) {
          text += playerLine(pl, m) + '\n';
        }
      }
      text += '\n';
    }

    const sorted = Object.entries(playerTotals).sort(([, a], [, b]) => b - a);
    if (sorted.length) {
      text += `\uD83D\uDCCA *Puntos ${j.jornada}:*\n`;
      sorted.forEach(([name, pts], i) => {
        const medal = i === 0 ? '\uD83E\uDD47' : i === 1 ? '\uD83E\uDD48' : i === 2 ? '\uD83E\uDD49' : `${i+1}.`;
        text += `${medal} ${name} \u2192 ${pts}pts\n`;
      });
    }

    waShare(text);
  }

  function shareDay(ji: number, dayKey: string) {
    const j = getData()[ji];
    if (!j) return;
    const matches = j.matches.filter(m => m.dayKey === dayKey);
    if (!matches.length) return;
    const title = (matches[0].dayLabel || 'Día').toUpperCase();

    let text = `⚽ *POLLA 2026 · ${title}*\n\n`;
    const playerTotals: Record<string, number> = {};
    for (const m of matches) {
      const hf = flagFromISO(m.homeISO);
      const af = flagFromISO(m.awayISO);
      if (m.finished && m.hs !== null) {
        let header = `*${m.home} ${hf} ${m.hs}–${m.as_} ${af} ${m.away}*`;
        if (m.winnerPen) {
          const winner   = m.winnerPen === 'home' ? m.home : m.away;
          const penScore = m.homePen !== null ? `${m.homePen}–${m.awayPen} pen` : 'pen';
          header += `\n_(${penScore} · clasifica ${winner})_`;
        }
        text += header + '\n';
        for (const pl of m.players) {
          text += playerLine(pl, m) + '\n';
          if (pl.uh !== null) playerTotals[pl.name] = (playerTotals[pl.name] ?? 0) + (pl.pts ?? 0);
        }
      } else {
        text += `*${m.home} ${hf} vs ${af} ${m.away}*\n`;
        for (const pl of m.players) text += playerLine(pl, m) + '\n';
      }
      text += '\n';
    }
    const sorted = Object.entries(playerTotals).sort(([, a], [, b]) => b - a);
    if (sorted.length) {
      text += `📊 *Puntos ${title}:*\n`;
      sorted.forEach(([name, pts], i) => {
        const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : `${i + 1}.`;
        text += `${medal} ${name} → ${pts}pts\n`;
      });
    }
    waShare(text);
  }

  // Cableado robusto: addEventListener + data-* (no depende del global `event`,
  // que no existe en Firefox → por eso el botón Jornada fallaba en PC).
  function initShareButtons() {
    document.querySelectorAll<HTMLButtonElement>('[data-share-jornada]').forEach(btn => {
      if (btn.dataset.shareInit) return;
      btn.dataset.shareInit = '1';
      btn.addEventListener('click', e => { e.preventDefault(); e.stopPropagation(); shareJornada(Number(btn.dataset.ji)); });
    });
    document.querySelectorAll<HTMLButtonElement>('[data-share-day]').forEach(btn => {
      if (btn.dataset.shareInit) return;
      btn.dataset.shareInit = '1';
      btn.addEventListener('click', e => { e.preventDefault(); e.stopPropagation(); shareDay(Number(btn.dataset.ji), btn.dataset.day ?? ''); });
    });
    document.querySelectorAll<HTMLButtonElement>('[data-share-match]').forEach(btn => {
      if (btn.dataset.shareInit) return;
      btn.dataset.shareInit = '1';
      btn.addEventListener('click', e => { e.preventDefault(); e.stopPropagation(); shareMatch(Number(btn.dataset.ji), Number(btn.dataset.mi)); });
    });
  }

  initShareButtons();
  document.addEventListener('astro:page-load', initShareButtons);

  // ── Controles: filtro por jugador, toggles de estado, salto y contraer/expandir ──
  function initFilters() {
    const root = document.getElementById('pron-root');
    if (!root || root.dataset.filtersInit) return;
    root.dataset.filtersInit = '1';

    const matches  = Array.from(document.querySelectorAll<HTMLElement>('[data-match]'));
    const dayseps  = Array.from(document.querySelectorAll<HTMLElement>('[data-daysep]'));
    const jornadas = Array.from(document.querySelectorAll<HTMLDetailsElement>('details[data-jornada]'));
    const emptyMsg = document.getElementById('filter-empty');
    let statusFilter = 'all';

    // La barra debe pegarse JUSTO debajo del nav sticky del Layout (no detrás).
    const toolbar = document.getElementById('pron-toolbar');
    const nav = document.querySelector('nav');
    const placeToolbar = () => { if (toolbar && nav) toolbar.style.top = nav.getBoundingClientRect().height + 'px'; };
    placeToolbar();
    window.addEventListener('resize', placeToolbar);

    function applyStatus() {
      let anyVisible = false;
      for (const el of matches) {
        const st = el.dataset.status;            // finished | closed | open
        const today = el.dataset.today === '1';
        let show = true;
        if (statusFilter === 'today')         show = today;
        else if (statusFilter === 'finished') show = st === 'finished';
        else if (statusFilter === 'pending')  show = st !== 'finished';
        el.classList.toggle('hidden-f', !show);
        if (show) anyVisible = true;
      }
      for (const sep of dayseps) {
        const vis = matches.some(m => m.dataset.ji === sep.dataset.ji && m.dataset.day === sep.dataset.day && !m.classList.contains('hidden-f'));
        sep.classList.toggle('hidden-f', !vis);
      }
      for (const det of jornadas) {
        const vis = !!det.querySelector('[data-match]:not(.hidden-f)');
        det.classList.toggle('hidden-f', !vis);
        if (statusFilter !== 'all' && vis) det.open = true;
      }
      if (emptyMsg) emptyMsg.classList.toggle('hidden', anyVisible);
    }

    document.querySelectorAll<HTMLButtonElement>('.status-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        statusFilter = btn.dataset.statusFilter || 'all';
        document.querySelectorAll<HTMLButtonElement>('.status-btn').forEach(b => {
          const on = b === btn;
          b.classList.toggle('bg-brand-700', on);
          b.classList.toggle('text-white', on);
          b.classList.toggle('text-slate-400', !on);
        });
        applyStatus();
      });
    });

    // Filtro por jugador → aislar (inyecta la regla CSS del seleccionado)
    const sel = document.getElementById('filter-player') as HTMLSelectElement | null;
    let isoStyle = document.getElementById('iso-style') as HTMLStyleElement | null;
    sel?.addEventListener('change', () => {
      const id = sel.value;
      if (!isoStyle) {
        isoStyle = document.createElement('style');
        isoStyle.id = 'iso-style';
        document.head.appendChild(isoStyle);
      }
      if (id) {
        root.setAttribute('data-iso', '');
        isoStyle.textContent = `#pron-root[data-iso] .pred-cell[data-pl="${id}"]{display:flex!important}`;
      } else {
        root.removeAttribute('data-iso');
        isoStyle.textContent = '';
      }
    });

    // Contraer / expandir todo
    const toggleAll = document.getElementById('toggle-all') as HTMLButtonElement | null;
    toggleAll?.addEventListener('click', () => {
      const expand = toggleAll.dataset.mode === 'expand';
      jornadas.forEach(d => { if (!d.classList.contains('hidden-f')) d.open = expand; });
      toggleAll.dataset.mode = expand ? 'collapse' : 'expand';
      toggleAll.textContent = expand ? '⊖ Contraer todo' : '⊕ Expandir todo';
    });
  }

  initFilters();
  document.addEventListener('astro:page-load', initFilters);
</script>
