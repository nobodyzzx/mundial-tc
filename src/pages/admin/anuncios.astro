---
import Layout from '@/layouts/Layout.astro';
import { createRequestClient, supabaseAdmin } from '@/lib/supabase';
import { fmtFecha } from '@/lib/fechas';
import { mdToHtml } from '@/lib/markdown';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
if (!accessToken || !refreshToken) { Astro.cookies.delete('sb-access-token', { path: '/' }); Astro.cookies.delete('sb-refresh-token', { path: '/' }); return Astro.redirect('/login'); }

const supabase = createRequestClient(); // sesión aislada por petición (ver lib/supabase)
const { data: { user } } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
if (!user) { Astro.cookies.delete('sb-access-token', { path: '/' }); Astro.cookies.delete('sb-refresh-token', { path: '/' }); return Astro.redirect('/login'); }

const { data: navProfile } = await supabase.from('profiles').select('username, puntos_totales, es_referi').eq('id', user.id).single();
if (!navProfile?.es_referi) return Astro.redirect('/dashboard');

const { data: rows } = await supabaseAdmin
  .from('announcements')
  .select('id, body, author_name, created_at, sent_to_whatsapp')
  .order('created_at', { ascending: false })
  .limit(50);

const anuncios = (rows ?? []).map((a: any) => ({
  ...a,
  cuando: fmtFecha(a.created_at, { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }),
}));

const msg = Astro.url.searchParams.get('msg');
const err = Astro.url.searchParams.get('err');
---

<Layout title="Tablón" navProfile={navProfile} isAuthed={true}>
  <div class="max-w-3xl mx-auto space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between gap-2">
      <div>
        <h1 class="font-display text-4xl text-white tracking-wide">📣 TABLÓN</h1>
        <p class="text-slate-400 text-sm mt-1">Publica un anuncio para todos · opción de enviarlo al grupo de WhatsApp</p>
      </div>
      <a href="/admin" class="text-xs text-slate-400 hover:text-white transition px-3 py-1.5 border border-brand-700 rounded-lg flex-shrink-0">← Panel VAR</a>
    </div>

    {(msg || err) && (
      <div class={`rounded-xl px-4 py-3 text-sm font-medium ${err ? 'bg-fifared/15 border border-fifared/40 text-red-200' : 'bg-gol/15 border border-gol/40 text-green-200'}`}>
        {err ? `⚠️ ${err}` : `✓ ${msg}`}
      </div>
    )}

    <!-- Publicar -->
    <div class="bg-gradient-to-b from-brand-900 to-brand-900/50 border border-gold/30 rounded-2xl p-5 sm:p-6 space-y-5 shadow-lg shadow-black/20">
      <div class="flex items-center gap-2.5">
        <span class="w-9 h-9 rounded-full bg-gold/15 border border-gold/30 flex items-center justify-center text-lg flex-shrink-0">📣</span>
        <div>
          <h2 class="font-display text-2xl text-white tracking-wide leading-none">Nuevo anuncio</h2>
          <p class="text-xs text-slate-400 mt-1">Firmado como <span class="text-gold font-semibold">{navProfile.username}</span>, la Réferi.</p>
        </div>
      </div>

      <form method="POST" action="/api/admin/announce" id="form-anuncio" class="space-y-4">
        <div class="space-y-1.5">
          <label for="ta-body" class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Mensaje</label>
          <textarea id="ta-body" name="body" required rows="6" maxlength="2000"
            placeholder="Ej: Recordatorio: los pronósticos de la Jornada 2 cierran hoy a las 15:00. ¡No se duerman!"
            class="w-full bg-brand-800 border border-brand-700 rounded-xl px-4 py-3 text-base text-white placeholder-slate-500 focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/30 transition resize-y"></textarea>
        </div>

        <!-- Enviar al grupo de WhatsApp -->
        <label class="flex items-center gap-3 bg-brand-800/60 border border-brand-700 rounded-xl px-4 py-3 cursor-pointer select-none">
          <input type="checkbox" name="notify" checked class="w-5 h-5 rounded accent-gol flex-shrink-0" />
          <span class="text-sm text-slate-200">📢 Enviar también al grupo de WhatsApp</span>
        </label>

        <button type="submit"
          class="w-full bg-gradient-to-r from-gold-light to-gold text-brand-950 font-extrabold py-3.5 rounded-xl text-base shadow-lg shadow-gold/25 transition hover:shadow-gold/40 active:scale-[0.99]">
          Publicar anuncio
        </button>
      </form>
    </div>

    <!-- Historial / tablón -->
    <div class="space-y-3">
      <h2 class="font-display text-2xl text-white tracking-wide">Publicados</h2>

      {anuncios.length === 0 && (
        <p class="text-slate-400 text-sm bg-brand-900 border border-brand-700/60 rounded-2xl px-4 py-6 text-center">
          Todavía no hay anuncios. Publica el primero arriba.
        </p>
      )}

      {anuncios.map((a) => (
        <div class="bg-brand-900 border border-brand-700/60 rounded-2xl p-4 space-y-2">
          <div class="flex items-center justify-between gap-2 text-xs">
            <span class="text-slate-400">
              <span class="text-gold font-semibold">{a.author_name}</span> · {a.cuando}
            </span>
            <span class="flex items-center gap-2 flex-shrink-0">
              {a.sent_to_whatsapp
                ? <span class="text-green-300 bg-gol/15 border border-gol/30 rounded-full px-2 py-0.5">📲 Enviado al grupo</span>
                : <span class="text-slate-400 bg-brand-800 border border-brand-700 rounded-full px-2 py-0.5">Solo tablón</span>}
              <form method="POST" action="/api/admin/announce" class="form-del-anuncio inline">
                <input type="hidden" name="_action" value="delete" />
                <input type="hidden" name="id" value={a.id} />
                <button type="submit" class="text-slate-500 hover:text-fifared transition" aria-label="Eliminar" title="Eliminar del tablón">🗑️</button>
              </form>
            </span>
          </div>
          <div class="text-sm text-slate-100 leading-relaxed space-y-1 [&_strong]:text-white [&_a]:text-gold" set:html={mdToHtml(a.body)} />
        </div>
      ))}
    </div>

  </div>

  <script is:inline>
    document.addEventListener('submit', function (e) {
      const f = e.target;
      if (f.classList && f.classList.contains('form-del-anuncio')) {
        if (!confirm('¿Eliminar este anuncio del tablón? (No borra el mensaje ya enviado a WhatsApp.)')) e.preventDefault();
      }
    });
  </script>
</Layout>
