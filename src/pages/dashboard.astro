---
import Layout from '@/layouts/Layout.astro';
import { supabase } from '@/lib/supabase';
import { betaNow, betaNowMs } from '@/lib/betaTime';
import { spanishName, isoForTeam } from '@/lib/isoFlags';
import { resumenPozo } from '@/lib/payments';
import { fmtFecha } from '@/lib/fechas';

// Auth guard
const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
if (!accessToken || !refreshToken) {
  Astro.cookies.delete('sb-access-token', { path: '/' });
  Astro.cookies.delete('sb-refresh-token', { path: '/' });
  return Astro.redirect('/login');
}

const { data: { user } } = await supabase.auth.setSession({
  access_token: accessToken,
  refresh_token: refreshToken,
});
if (!user) {
  Astro.cookies.delete('sb-access-token', { path: '/' });
  Astro.cookies.delete('sb-refresh-token', { path: '/' });
  return Astro.redirect('/login');
}

const ahora = betaNow().toISOString();

// Todas las queries en paralelo — una sola ronda de red
const [
  { data: standings },
  { data: sanctions },
  { data: proximosPartidosRaw },
  { data: myProfile },
  { data: recentFinished },
  { data: startedMatchData },
] = await Promise.all([
  supabase.from('profiles').select('id, username, puntos_totales, es_referi, participa, monto_pagado').eq('expulsado', false).eq('participa', true).order('puntos_totales', { ascending: false }),
  supabase.from('sanctions').select('user_id, type').eq('active', true),
  supabase.from('matches').select('*').eq('is_finished', false).gte('match_date', ahora).order('match_date', { ascending: true }).limit(6),
  supabase.from('profiles').select('username, puntos_totales, es_referi').eq('id', user.id).single(),
  supabase.from('matches').select('id, home_team, away_team, home_score, away_score, home_pen, away_pen, winner_penalties, match_date, jornada, stage').eq('is_finished', true).order('match_date', { ascending: false }).limit(20),
  supabase.from('matches').select('match_date, is_finished').lte('match_date', ahora),
]);

// Un partido en curso (IN_PLAY/PAUSED) no es "próximo": lo excluimos de la lista.
const proximosPartidos = (proximosPartidosRaw ?? []).filter((m: any) => !['IN_PLAY', 'PAUSED'].includes(m.status));

// Mapa userId → { yellows, reds }
const sanctionMap = new Map<string, { yellows: number; reds: number }>();
for (const s of sanctions ?? []) {
  const cur = sanctionMap.get(s.user_id) ?? { yellows: 0, reds: 0 };
  if (s.type === 'yellow') cur.yellows++;
  else if (s.type === 'red' || s.type === 'double_red') cur.reds++;
  sanctionMap.set(s.user_id, cur);
}

// Datos para calcular estados de bloqueo (igual que predictions/index.astro)
function toBoliviaDay(dateStr: string): string {
  return fmtFecha(dateStr, {
    weekday: 'long', day: 'numeric', month: 'long',
  });
}

const daysWithStartedMatch = new Set(
  (startedMatchData ?? []).map((m: any) => toBoliviaDay(m.match_date))
);
const hasMatchInProgress = (startedMatchData ?? []).some((m: any) => !m.is_finished);

// Agrupa próximos partidos por día Bolivia para calcular primer partido del día
const upcomingByDay = new Map<string, any[]>();
for (const m of (proximosPartidos ?? [])) {
  const key = toBoliviaDay(m.match_date);
  if (!upcomingByDay.has(key)) upcomingByDay.set(key, []);
  upcomingByDay.get(key)!.push(m);
}

function getMatchLockState(m: any): 'prevPending' | 'ongoingLock' | 'closed' | 'open' {
  const dayKey = toBoliviaDay(m.match_date);
  const dayMatches = upcomingByDay.get(dayKey) ?? [m];
  const firstTime = Math.min(...dayMatches.map((dm: any) => new Date(dm.match_date).getTime()));
  const nowMs = betaNowMs();

  // Regla 2h → cerrado simple
  if (firstTime - nowMs < 2 * 3600 * 1000) return 'closed';

  // Mismo día ya empezó → ongoingLock
  const sameDayStarted = daysWithStartedMatch.has(dayKey);

  // Jornada anterior pendiente: partidos ya iniciados sin terminar O partidos
  // futuros de una jornada anterior (no alcanzados por startedMatchData)
  const hasPrevUnfinished = (startedMatchData ?? []).some(
    (sm: any) => !sm.is_finished && new Date(sm.match_date).getTime() < firstTime
  );
  const hasEarlierUpcoming = (proximosPartidos ?? []).some(
    (pm: any) => new Date(pm.match_date).getTime() < firstTime
  );
  if (!sameDayStarted && (hasPrevUnfinished || hasEarlierUpcoming)) return 'prevPending';

  if (sameDayStarted || hasMatchInProgress) return 'ongoingLock';

  return 'open';
}

// Prediction status for upcoming matches
const upcomingMatchIds = (proximosPartidos ?? []).map((m: any) => m.id);
let predictedSet = new Set<string>();
if (upcomingMatchIds.length > 0) {
  const { data: myPreds } = await supabase
    .from('predictions')
    .select('match_id')
    .eq('user_id', user.id)
    .in('match_id', upcomingMatchIds);
  predictedSet = new Set((myPreds ?? []).map((p: any) => p.match_id));
}

// Última jornada terminada
const finishedList = recentFinished ?? [];
const lastJornadaName = finishedList.length > 0 ? finishedList[0].jornada : null;
const lastJornadaMatches = lastJornadaName
  ? finishedList.filter((m: any) => m.jornada === lastJornadaName)
  : finishedList.slice(0, 6);

const MEDALS = ['🥇', '🥈', '🥉'];

// En knockout el rival puede ser un slot de bracket sin definir (ej. "1E", "3ABCDF").
// Un equipo real siempre tiene bandera ISO; si no la tiene, aún no está determinado.
function teamLabel(name: string): string {
  return isoForTeam(name) ? spanishName(name) : 'Por definir';
}

type StandingRow = {
  id: string;
  username: string;
  puntos_totales: number;
  es_referi: boolean;
  monto_pagado: number;
};

const rows: StandingRow[] = standings ?? [];
const today = fmtFecha(betaNow(), {
  weekday: 'long', day: 'numeric', month: 'long',
});

// navProfile viene de su propia query — independiente del filtro participa
const navProfile = myProfile ?? null;

// Premio/réferi derivados de monto_pagado (lib/payments) — todos pagaron
const leaderPoints = rows[0]?.puntos_totales ?? 0;
const { pozo: pozoActual, referi: montoReferi } = resumenPozo(rows.map(r => r.monto_pagado));
const myRank = rows.findIndex(r => r.id === user.id) + 1; // 0 si no participa
const nextMatch = (proximosPartidos ?? [])[0] ?? null;

// Próximo partido — countdown
function countdownLabel(matchDate: string): string {
  const diff = new Date(matchDate).getTime() - betaNowMs();
  if (diff <= 0) return 'En curso';
  const h = Math.floor(diff / 3600000);
  if (h < 1) {
    const m = Math.floor(diff / 60000);
    return `${m} min`;
  }
  if (h < 24) return `${h}h ${Math.floor((diff % 3600000) / 60000)}m`;
  const d = Math.floor(h / 24);
  const rh = h % 24;
  return rh > 0 ? `${d}d ${rh}h` : `${d} días`;
}

// Estilos por posición
function rowStyle(i: number, isMe: boolean) {
  if (isMe) return 'bg-brand-700/30 border border-brand-600/60';
  if (i === 0) return 'bg-yellow-500/10 border border-yellow-500/35';
  if (i === 1) return 'bg-slate-400/10 border border-slate-400/30';
  if (i === 2) return 'bg-amber-700/10 border border-amber-700/30';
  return i % 2 === 0 ? 'bg-brand-900 border border-brand-800/60' : 'bg-brand-800/40 border border-brand-700/40';
}
function pointColor(i: number, isMe: boolean) {
  if (isMe) return 'text-brand-400';
  if (i === 0) return 'text-gold';
  if (i === 1) return 'text-slate-300';
  if (i === 2) return 'text-amber-600';
  return 'text-white';
}
function accentLine(i: number, isMe: boolean) {
  if (isMe) return 'from-transparent via-blue-400/70 to-transparent';
  if (i === 0) return 'from-transparent via-gold to-transparent';
  if (i === 1) return 'from-transparent via-slate-400/70 to-transparent';
  if (i === 2) return 'from-transparent via-amber-600/70 to-transparent';
  return 'from-transparent via-brand-600/40 to-transparent';
}
---

<Layout title="Tabla" navProfile={navProfile} isAuthed={true}>
  <div class="space-y-8">

    <!-- Header -->
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="font-display text-4xl text-white tracking-wide">TABLA DE POSICIONES</h1>
        <span class="text-sm text-slate-500 capitalize">{today}</span>
      </div>
      {navProfile?.es_referi && (
        <div class="flex flex-col gap-2 self-start sm:self-auto sm:items-end">
          <div class="flex gap-2 flex-wrap">
            <!-- Compartir tabla -->
            <button id="btn-share-tabla"
              class="flex items-center gap-2 bg-[#25D366]/10 border border-[#25D366]/30 text-[#25D366] text-sm font-semibold px-4 py-2.5 rounded-xl transition active:bg-[#25D366]/20">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 flex-shrink-0">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.532 5.859L.057 23.428a.5.5 0 0 0 .609.61l5.699-1.451A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-4.964-1.347l-.356-.211-3.683.938.974-3.562-.232-.367A9.818 9.818 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
              </svg>
              Tabla
            </button>
          </div>
        </div>
      )}
    </div>
    {/* ── MIS PRÓXIMOS PARTIDOS — acceso rápido a pronosticar ── */}
    {proximosPartidos && proximosPartidos.length > 0 && (
      <section class="rounded-2xl border border-gold/40 bg-gradient-to-br from-brand-900 to-brand-800/40 overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-brand-700/50">
          <h2 class="font-display text-xl text-white tracking-wide">⚽ MIS PRÓXIMOS PARTIDOS</h2>
          {nextMatch && <span class="text-xs text-gold font-semibold flex-shrink-0">⏱ {countdownLabel(nextMatch.match_date)}</span>}
        </div>
        <div class="divide-y divide-brand-800/60">
          {proximosPartidos.map((m: any) => {
            const lockState = getMatchLockState(m);
            const isOpen = lockState === 'open';
            const hasPredicted = predictedSet.has(m.id);
            const row = (
              <div class="flex items-center gap-3 px-4 py-3">
                <div class="flex-1 min-w-0">
                  <div class="text-sm font-semibold text-white truncate">
                    {teamLabel(m.home_team)} <span class="text-slate-600 font-normal">vs</span> {teamLabel(m.away_team)}
                  </div>
                  <div class="text-xs text-slate-500 mt-0.5">
                    {fmtFecha(m.match_date, { weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}
                  </div>
                </div>
                <span class={`text-xs font-semibold flex-shrink-0 ${
                  hasPredicted               ? 'text-gol' :
                  isOpen                     ? 'text-gold' :
                  lockState === 'closed'     ? 'text-fifared' :
                  'text-slate-500'
                }`}>
                  {hasPredicted               ? '✓ Pronosticado' :
                   isOpen                     ? 'Pronosticar →' :
                   lockState === 'closed'     ? '🔒 Cerrada' :
                   lockState === 'ongoingLock'? '⏳ En curso' :
                   '⏳ Espera'}
                </span>
              </div>
            );
            return isOpen && !hasPredicted
              ? <a href={`/predictions/${m.id}`} class="block transition active:bg-brand-800/50">{row}</a>
              : row;
          })}
        </div>
        <a href="/predictions" class="block text-center text-sm font-bold py-3.5 bg-gold text-brand-950 transition active:opacity-80">
          Ir a mis pronósticos →
        </a>
      </section>
    )}

    <script is:inline type="application/json" id="standings-data" set:html={JSON.stringify(rows.map((p, i) => ({ pos: i + 1, username: p.username ?? '?', pts: p.puntos_totales ?? 0 })))}></script>
    <script is:inline type="application/json" id="standings-meta" set:html={JSON.stringify({ pozoActual, montoReferi })}></script>

    <!-- STATS CARDS -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <!-- Participantes -->
      <div class="relative overflow-hidden rounded-2xl px-4 py-3 flex flex-col gap-1">
        <div class="absolute inset-0 bg-gradient-to-br from-violet-600 to-indigo-800"></div>
        <div class="absolute -top-4 -right-4 w-16 h-16 bg-white/10 rounded-full blur-xl"></div>
        <span class="relative text-xs text-white/70 uppercase tracking-wide">Jugadores</span>
        <span class="relative text-2xl">👥</span>
        <span class="relative font-display text-3xl text-white leading-none">{rows.length}</span>
      </div>

      <!-- Mi posición · Réferi -->
      {navProfile?.es_referi ? (
        <a href="/admin" class="relative overflow-hidden rounded-2xl px-4 py-3 flex flex-col gap-1 group transition active:scale-95">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-600 to-teal-800"></div>
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/80 to-teal-700/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute -top-4 -right-4 w-16 h-16 bg-white/10 rounded-full blur-xl"></div>
          <span class="relative text-xs text-white/70 uppercase tracking-wide">Mi rol</span>
          <span class="relative text-2xl">⚖️</span>
          <span class="relative font-display text-3xl text-white leading-none">Réferi</span>
        </a>
      ) : (
        <a href="/predictions" class="relative overflow-hidden rounded-2xl px-4 py-3 flex flex-col gap-1 group transition active:scale-95">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-600 to-teal-800"></div>
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/80 to-teal-700/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute -top-4 -right-4 w-16 h-16 bg-white/10 rounded-full blur-xl"></div>
          <span class="relative text-xs text-white/70 uppercase tracking-wide">Mi posición</span>
          <span class="relative text-2xl">🏅</span>
          <span class="relative font-display text-3xl text-white leading-none">
            {myRank > 0 ? <Fragment>#{myRank}<span class="text-white/40 text-base font-sans"> / {rows.length}</span></Fragment> : '—'}
          </span>
        </a>
      )}

      <!-- Próximo partido -->
      {nextMatch ? (
        <div class="relative overflow-hidden rounded-2xl px-4 py-3 flex flex-col gap-1">
          <div class="absolute inset-0 bg-gradient-to-br from-amber-500 to-orange-700"></div>
          <div class="absolute -top-4 -right-4 w-16 h-16 bg-white/10 rounded-full blur-xl"></div>
          <span class="relative text-xs text-white/70 uppercase tracking-wide">Próximo partido</span>
          <span class="relative text-2xl">⚽</span>
          <span class="relative font-display text-3xl text-white leading-none">{countdownLabel(nextMatch.match_date)}</span>
          <span class="relative text-xs text-white/60 truncate">{teamLabel(nextMatch.home_team)} vs {teamLabel(nextMatch.away_team)}</span>
        </div>
      ) : (
        <div class="relative overflow-hidden rounded-2xl px-4 py-3 flex flex-col gap-1">
          <div class="absolute inset-0 bg-gradient-to-br from-amber-500 to-orange-700"></div>
          <div class="absolute -top-4 -right-4 w-16 h-16 bg-white/10 rounded-full blur-xl"></div>
          <span class="relative text-xs text-white/70 uppercase tracking-wide">Próximo partido</span>
          <span class="relative text-2xl">⚽</span>
          <span class="relative text-sm text-white/50">
            {recentFinished && recentFinished.length > 0 ? 'No hay más partidos programados' : 'El torneo aún no ha comenzado'}
          </span>
        </div>
      )}
      <!-- Resultados -->
      <a href="/resultados" class="relative overflow-hidden rounded-2xl px-4 py-3 flex flex-col gap-1 group transition active:scale-95">
        <div class="absolute inset-0 bg-gradient-to-br from-sky-600 to-blue-800"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-sky-500/80 to-blue-700/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="absolute -top-4 -right-4 w-16 h-16 bg-white/10 rounded-full blur-xl"></div>
        <span class="relative text-xs text-white/70 uppercase tracking-wide">Resultados</span>
        <span class="relative text-2xl">📋</span>
        <span class="relative font-display text-3xl text-white leading-none">Ver →</span>
      </a>
    </div>

    <!-- PREMIO AL GANADOR (compacto) -->
    <div class="relative overflow-hidden rounded-2xl px-5 py-4">
      <div class="absolute inset-0 bg-gradient-to-br from-yellow-600 to-amber-800"></div>
      <div class="absolute -top-6 -right-6 w-28 h-28 bg-white/10 rounded-full blur-2xl"></div>
      <div class="absolute -bottom-4 -left-4 w-20 h-20 bg-black/10 rounded-full blur-xl"></div>
      <div class="relative flex items-center gap-4">
        <span class="text-5xl drop-shadow-[0_4px_12px_rgba(0,0,0,0.35)] select-none flex-shrink-0">🏆</span>
        <div class="flex-1 min-w-0">
          <span class="text-xs text-white/70 uppercase tracking-wide">Premio al ganador</span>
          <div class="flex items-baseline gap-x-2 gap-y-0 flex-wrap">
            <span class="font-display text-4xl text-white leading-none drop-shadow-[0_2px_8px_rgba(0,0,0,0.3)]">{pozoActual} Bs</span>
            <span class="text-xs text-white/70">· ⚖️ Réferi {montoReferi} Bs</span>
          </div>
          <p class="text-xs text-white/80 italic mt-1.5 leading-snug">El campeón ostentará el título 4 años y derecho ilimitado a fanfarronear. 😏</p>
        </div>
      </div>
    </div>

    <!-- STANDINGS — mobile cards / desktop table -->
    <div>

      <!-- Mobile: cards -->
      <div class="flex flex-col gap-2 sm:hidden">
        {rows.map((p, i) => {
          const gap = leaderPoints - p.puntos_totales;
          const isMe = p.id === user.id;
          return (
            <div class={`relative rounded-2xl pl-5 pr-4 py-3 flex items-center gap-3 overflow-hidden ${rowStyle(i, isMe)}`}>

              {/* Línea difuminada izquierda */}
              <div class={`absolute left-0 top-0 bottom-0 w-[3px] bg-gradient-to-b ${accentLine(i, isMe)}`} />

              <div class="text-2xl w-8 text-center flex-shrink-0">
                {MEDALS[i] !== undefined ? MEDALS[i] : <span class="font-mono text-slate-500 text-sm">{i + 1}</span>}
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class={`font-semibold text-base ${isMe ? 'text-white' : i === rows.length - 1 ? 'text-slate-600' : 'text-slate-100'}`}>
                    {p.username}
                  </span>
                  {isMe && <span class="text-xs text-brand-400 font-medium">(tú)</span>}
                  {i === rows.length - 1 && rows.length > 1 && <span class="text-xs font-bold text-fifared tracking-widest">👻 LOSER!!</span>}
                  {p.es_referi && <span class="text-xs text-gold">⚖️</span>}
                  {(() => { const s = sanctionMap.get(p.id); return s ? (
                    <span class="flex gap-0.5">
                      {'🟨'.repeat(s.yellows)}{'🟥'.repeat(s.reds)}
                    </span>
                  ) : null; })()}
                </div>
                {gap > 0 && (
                  <div class="flex items-center gap-2 mt-0.5">
                    <span class="text-xs text-slate-600">−{gap} pts</span>
                  </div>
                )}
              </div>
              <div class="text-right flex-shrink-0">
                <span class={`font-display text-3xl tabular-nums ${pointColor(i, isMe)}`}>
                  {p.puntos_totales}
                </span>
                <div class="text-xs text-slate-600">pts</div>
              </div>
            </div>
          );
        })}
        {rows.length === 0 && (
          <div class="text-center py-12 text-slate-600 text-base">
            Aún no hay participantes registrados.
          </div>
        )}
      </div>

      <!-- Desktop: table -->
      <div class="hidden sm:block bg-brand-900 border border-brand-800 rounded-2xl overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-brand-800 text-slate-500 text-xs uppercase">
              <th class="px-4 py-3 text-left w-10">#</th>
              <th class="px-4 py-3 text-left">Jugador</th>
              <th class="px-4 py-3 text-right">Puntos</th>
              <th class="px-4 py-3 text-center hidden md:table-cell">Diferencia</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((p, i) => {
              const gap = leaderPoints - p.puntos_totales;
              const isMe = p.id === user.id;
              return (
                <tr class={`border-b border-brand-800/40 ${isMe ? 'bg-brand-700/20' : i === 0 ? 'bg-yellow-500/8' : i === 1 ? 'bg-slate-400/5' : i === 2 ? 'bg-amber-700/8' : i % 2 === 0 ? '' : 'bg-brand-800/30'}`}>
                  <td class="py-3 pl-0 pr-4 font-mono text-lg w-10">
                    <div class="flex items-center gap-2 h-full">
                      <div class={`w-[3px] h-8 rounded-full bg-gradient-to-b flex-shrink-0 ${accentLine(i, isMe)}`} />
                      {MEDALS[i] !== undefined ? MEDALS[i] : <span class="text-slate-500 text-sm">{i + 1}</span>}
                    </div>
                  </td>
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-2">
                      <span class={`font-semibold ${isMe ? 'text-white' : i === rows.length - 1 ? 'text-slate-600' : 'text-slate-100'}`}>
                        {p.username}
                      </span>
                      {isMe && <span class="text-xs text-brand-400">(tú)</span>}
                      {i === rows.length - 1 && rows.length > 1 && <span class="text-xs font-bold text-fifared tracking-widest">👻 LOSER!!</span>}
                      {p.es_referi && <span class="text-gold text-xs">⚖️</span>}
                      {(() => { const s = sanctionMap.get(p.id); return s ? (
                        <span class="flex gap-0.5 text-sm">
                          {'🟨'.repeat(s.yellows)}{'🟥'.repeat(s.reds)}
                        </span>
                      ) : null; })()}
                    </div>
                  </td>
                  <td class="px-4 py-3 text-right">
                    <span class={`font-display text-2xl tabular-nums ${pointColor(i, isMe)}`}>
                      {p.puntos_totales}
                    </span>
                    <span class="text-slate-600 text-xs ml-1">pts</span>
                  </td>
                  <td class="px-4 py-3 text-center hidden md:table-cell">
                    {leaderPoints === 0
                      ? <span class="text-slate-600 text-xs">—</span>
                      : gap > 0
                        ? <span class="text-slate-500 text-xs">−{gap}</span>
                        : <span class="text-gold text-xs">líder</span>
                    }
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
        {rows.length === 0 && (
          <div class="text-center py-12 text-slate-600">
            Aún no hay participantes registrados.
          </div>
        )}
      </div>
    </div>

    <!-- RESUMEN ÚLTIMA JORNADA -->
    {lastJornadaMatches.length > 0 && (
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <h2 class="font-display text-2xl text-white tracking-wide">ÚLTIMA JORNADA</h2>
          {lastJornadaName && <span class="text-xs text-slate-500 uppercase tracking-wide">{lastJornadaName}</span>}
        </div>
        <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
          {lastJornadaMatches.map((m: any) => {
            // En knockout destacamos al que clasifica (dorado) y atenuamos/tachamos al
            // eliminado: por penales si los hubo, si no por marcador. Penales en paréntesis.
            const winner = m.winner_penalties
              ?? (m.stage === 'knockout' && m.home_score !== m.away_score
                    ? (m.home_score > m.away_score ? 'home' : 'away')
                    : null);
            const pen = !!m.winner_penalties;
            return (
              <div class="bg-brand-900 border border-brand-800/60 rounded-xl px-4 py-3">
                <div class="flex items-center justify-between gap-2 text-sm font-semibold">
                  <span class={`truncate flex-1 ${winner === 'home' ? 'text-gold' : winner === 'away' ? 'text-slate-500 line-through' : 'text-white'}`}>{spanishName(m.home_team)}</span>
                  <span class="shrink-0 flex items-center gap-1.5 font-display text-lg tabular-nums">
                    {pen && <span class="font-sans text-[10px] font-bold text-gold bg-gold/15 border border-gold/40 rounded px-1.5 py-0.5 leading-none">PEN</span>}
                    <span class={winner === 'away' ? 'text-slate-500' : 'text-gold'}>
                      {m.home_score}{pen && <span class="text-xs"> ({m.home_pen})</span>}
                    </span>
                    <span class="text-slate-500">–</span>
                    <span class={winner === 'home' ? 'text-slate-500' : 'text-gold'}>
                      {pen && <span class="text-xs">({m.away_pen}) </span>}{m.away_score}
                    </span>
                  </span>
                  <span class={`truncate flex-1 text-right ${winner === 'away' ? 'text-gold' : winner === 'home' ? 'text-slate-500 line-through' : 'text-white'}`}>{spanishName(m.away_team)}</span>
                </div>
              </div>
            );
          })}
        </div>
        <a href="/resultados" class="inline-block text-xs text-brand-400 hover:text-brand-300 transition">
          Ver todos los pronósticos →
        </a>
      </div>
    )}

  </div>
</Layout>

<script>
// Forma del JSON embebido en el <script type="application/json"> de arriba.
interface StandingShare { pos: number; username: string; pts: number; }

// Se re-ejecuta en cada navegación (ClientRouter), no solo en la carga inicial,
// para que los botones de compartir queden enganchados también tras un swap SPA.
function waShareInit() {

  function showToast(msg: string) {
    var el = document.createElement('div');
    el.textContent = msg;
    el.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0d1117;border:1px solid #25d366;color:#fff;padding:12px 20px;border-radius:12px;font-size:14px;z-index:9999;pointer-events:none;white-space:nowrap';
    document.body.appendChild(el);
    setTimeout(function () { el.style.transition = 'opacity .3s'; el.style.opacity = '0'; setTimeout(function () { el.remove(); }, 300); }, 3500);
  }

  function waShare(text: string) {
    var isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
    if (isMobile) {
      // location.href no puede ser bloqueado por el navegador (es navegación, no popup)
      location.href = 'https://wa.me/?text=' + encodeURIComponent(text);
      return;
    }
    // Desktop: copiar al portapapeles
    navigator.clipboard.writeText(text)
      .then(function () { showToast('\uD83D\uDCCB Copiado \u2014 p\u00e9galo en WhatsApp con Ctrl+V'); })
      .catch(function () { showToast('\u26A0\uFE0F No se pudo copiar \u2014 c\u00f3pialo manualmente'); });
  }

  // ── Compartir tabla ──────────────────────────────────────
  var btnTabla = document.getElementById('btn-share-tabla');
  if (btnTabla) {
    btnTabla.addEventListener('click', function () {
      var rows: StandingShare[] = JSON.parse(document.getElementById('standings-data')!.textContent!);
      var meta = JSON.parse(document.getElementById('standings-meta')!.textContent!);
      var MEDALS = ['\uD83E\uDD47', '\uD83E\uDD48', '\uD83E\uDD49'];
      var lines = rows.map(function (p) {
        var medal = MEDALS[p.pos - 1] || (p.pos + '.');
        return medal + ' ' + p.username + ' \u2014 ' + p.pts + ' pts';
      });
      var text = [
        '\uD83C\uDFC6 *TABLA DE POSICIONES*',
        '_Polla Mundial 2026_',
        '',
      ].concat(lines).concat([
        '',
        '\uD83D\uDCB0 Pozo: ' + meta.pozoActual + ' Bs \u2502 \u2696\uFE0F R\u00e9feri: ' + meta.montoReferi + ' Bs',
        '\uD83D\uDD17 mundial.tecnocondor.dev',
      ]).join('\n');
      waShare(text);
    });
  }
}

document.addEventListener('astro:page-load', waShareInit);
</script>

