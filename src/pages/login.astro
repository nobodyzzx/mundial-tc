---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) return Astro.redirect('/dashboard');

const error = Astro.url.searchParams.get('error');
const message = Astro.url.searchParams.get('message');
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Entrar | Polla 2026</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <ClientRouter />
    <style>
      @keyframes spin-ball { to { transform: rotate(360deg); } }
      .spin-ball { display: inline-block; animation: spin-ball 0.7s linear infinite; }
    </style>
  </head>
  <script>
    import { polyfillCountryFlagEmojis } from 'country-flag-emoji-polyfill';
    polyfillCountryFlagEmojis();
  </script>
  <body class="min-h-screen antialiased">

    <!-- Background image + overlays -->
    <div
      class="fixed inset-0 bg-cover bg-center bg-no-repeat scale-105"
      style="background-image: url('/bg-login.jpg')"
    ></div>
    <!-- Gradiente vertical: da profundidad y oscurece bordes -->
    <div class="fixed inset-0 bg-gradient-to-b from-brand-950/72 via-brand-950/88 to-black/96"></div>
    <!-- Resplandor dorado de "luz de estadio" detrás del logo -->
    <div class="fixed inset-0 pointer-events-none"
      style="background: radial-gradient(58% 42% at 50% 17%, rgba(240,165,0,0.16), transparent 72%)"></div>

    <!-- Content -->
    <div class="relative z-10 min-h-screen flex flex-col items-center justify-center px-4 py-10">

      <!-- Logo & host countries -->
      <div class="relative mb-7 text-center">
        <!-- Halo radial dorado para realzar el trofeo sobre el fondo oscuro -->
        <div class="pointer-events-none absolute left-1/2 top-16 sm:top-20 -translate-x-1/2 -translate-y-1/2 h-48 w-48 rounded-full bg-gold/30 blur-3xl"></div>
        <img src="/trophy.svg" alt="Copa del Mundo FIFA"
          class="relative h-32 sm:h-40 mx-auto object-contain drop-shadow-[0_10px_28px_rgba(0,0,0,0.55)]" />
        <div class="relative inline-flex items-center gap-2.5 mt-4 px-3.5 py-1.5 rounded-full bg-white/8 border border-white/12 text-xl backdrop-blur-sm shadow-lg shadow-black/30">
          <span title="Estados Unidos">🇺🇸</span>
          <span title="Canadá">🇨🇦</span>
          <span title="México">🇲🇽</span>
        </div>
      </div>

      <!-- Card (borde con degradado dorado tipo "premium") -->
      <div class="w-full max-w-sm">
        <div class="rounded-[1.4rem] bg-gradient-to-b from-gold/45 via-brand-700/40 to-transparent p-px shadow-2xl shadow-black/50">
          <div class="rounded-[1.35rem] bg-gradient-to-b from-brand-900/92 to-brand-800/88 backdrop-blur-xl p-6 sm:p-8 space-y-5">

          <div class="text-center space-y-1.5">
            <span class="inline-block text-[0.65rem] font-bold tracking-[0.3em] text-gold/90 uppercase">Mundial 2026</span>
            <h1 class="text-2xl font-extrabold tracking-wide bg-gradient-to-r from-gold-light to-gold bg-clip-text text-transparent">Polla Mundial</h1>
            <p class="text-slate-300 text-sm">Predice. Compite. Gana. ⚽</p>
          </div>

          {error && (
            <div class="bg-fifared/20 border border-fifared/50 rounded-xl px-4 py-3 text-sm text-red-300 text-center">
              {error}
            </div>
          )}
          {message && (
            <div class="bg-gol/10 border border-gol/30 rounded-xl px-4 py-3 text-sm text-green-300 text-center">
              {message}
            </div>
          )}

          <form method="POST" action="/api/auth/login" class="space-y-4">
            <div class="space-y-1.5">
              <label class="text-sm text-slate-300 block font-medium">Correo electrónico</label>
              <input name="email" type="email" required placeholder="tu@correo.com"
                class="w-full bg-brand-950/60 border border-brand-700 rounded-xl px-4 py-3.5 text-base text-white placeholder-slate-500 focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/30 transition" />
            </div>
            <div class="space-y-1.5">
              <label class="text-sm text-slate-300 block font-medium">Contraseña</label>
              <div class="relative">
                <input id="password-input" name="password" type="password" required placeholder="••••••••"
                  class="w-full bg-brand-950/60 border border-brand-700 rounded-xl px-4 py-3.5 pr-12 text-base text-white placeholder-slate-500 focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/30 transition" />
                <button type="button" id="toggle-password"
                  class="absolute right-0 top-0 h-full w-12 flex items-center justify-center text-slate-500 hover:text-slate-300 transition touch-manipulation"
                  aria-label="Mostrar contraseña">
                  <svg id="icon-eye" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                  <svg id="icon-eye-off" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                  </svg>
                </button>
              </div>
            </div>
            <button type="submit"
              class="w-full bg-gradient-to-r from-gold-light to-gold text-brand-950 font-extrabold py-4 rounded-xl text-base min-h-[52px] mt-1 shadow-lg shadow-gold/25 transition hover:shadow-gold/40 active:scale-[0.99]">
              Entrar al Mundial ⚽
            </button>

            {/* Recuperación por correo oculta: los correos son de relleno
                (usuario@mundial.com) y no llega ningún email. El réferi resetea
                claves desde /admin/usuarios. */}
            <div class="pt-1 text-center">
              <div class="flex items-center gap-3 mb-3">
                <span class="h-px flex-1 bg-brand-700/70"></span>
                <span class="text-[0.65rem] uppercase tracking-widest text-slate-500">¿Olvidaste tu clave?</span>
                <span class="h-px flex-1 bg-brand-700/70"></span>
              </div>
              <p class="text-xs text-slate-400 leading-relaxed">
                Escríbele al réferi o a <span class="text-gold font-semibold">Harold</span> por WhatsApp 📲
              </p>
            </div>
          </form>

          </div>
        </div>

        <p class="text-center text-xs text-slate-500 mt-5">
          11 jun – 19 jul 2026 &middot; 48 selecciones &middot; 104 partidos
        </p>
      </div>
    </div>

  <script is:inline>
    document.addEventListener('click', function (e) {
      if (!e.target.closest('#toggle-password')) return;
      var input  = document.getElementById('password-input');
      var eye    = document.getElementById('icon-eye');
      var eyeOff = document.getElementById('icon-eye-off');
      if (!input || !eye || !eyeOff) return;
      var isPassword = input.type === 'password';
      input.setAttribute('type', isPassword ? 'text' : 'password');
      eye.classList.toggle('hidden', isPassword);
      eyeOff.classList.toggle('hidden', !isPassword);
    });

    var form = document.querySelector('form[action="/api/auth/login"]');
    var submitBtn = form ? form.querySelector('button[type="submit"]') : null;
    if (form && submitBtn) {
      form.addEventListener('submit', function () {
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.75';
        submitBtn.style.cursor = 'not-allowed';
        submitBtn.innerHTML = '<span class="spin-ball">⚽</span> Entrando...';
      });
    }
  </script>
  </body>
</html>
