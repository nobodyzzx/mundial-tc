# Credenciales del proyecto Supabase de PRUEBAS (distinto al de prod).
# Copiar a .env.test y rellenar con los valores del proyecto nuevo.
# Obtener en: Supabase Dashboard → Settings → API

TEST_SUPABASE_URL=https://[project-ref].supabase.co
TEST_SUPABASE_ANON_KEY=eyJ...
TEST_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URL de conexión directa a la BD (para apply-migrations.sh).
# Obtener en: Supabase Dashboard → Settings → Database → Connection String (URI)
# Cambiar [YOUR-PASSWORD] por la contraseña del proyecto.
TEST_DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
